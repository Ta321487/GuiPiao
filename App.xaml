<Application x:Class="GuiPiao.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="View/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!--
                全局资源由拆分字典合并，键与原先单文件 App.xaml 一致。
                ThemeManager 仍向 MergedDictionaries.Insert(0, 主题)，主题优先于下列静态合并项。
                合并顺序：与原先「DatePicker → TimePicker → 转换器 → 字号 → 样式」一致。
            -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="View/ThemedDatePicker.xaml" />
                <ResourceDictionary Source="View/ThemedTimePicker.xaml" />
                <ResourceDictionary Source="Resources/AppConverters.xaml" />
                <ResourceDictionary Source="Resources/AppThemeTokens.xaml" />
                <ResourceDictionary Source="Resources/AppControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
