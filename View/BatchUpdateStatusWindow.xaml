<Window x:Class="GuiPiao.View.BatchUpdateStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="批量修改状态"
        Width="500"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="批量修改车票状态"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15" />

        <!-- 选中的车票列表 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="选中的车票："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,5" />

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    MaxHeight="200">
                <DataGrid x:Name="TicketsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ThemedDataGridCellStyle}"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource NormalScrollBarStyle}" />
                            </Style.Resources>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}" />
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="车次" Binding="{Binding TrainNo}" Width="80" />
                        <DataGridTextColumn Header="出发站" Binding="{Binding DepartStation}" Width="90" />
                        <DataGridTextColumn Header="到达站" Binding="{Binding ArriveStation}" Width="90" />
                        <DataGridTextColumn Header="出发日期"
                                            Binding="{Binding DepartDate, Converter={StaticResource DateFormatConverter}}"
                                            Width="90" />
                        <DataGridTextColumn Header="当前状态" Binding="{Binding StatusDisplay}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- 跳过的车票提示 -->
        <Border Grid.Row="2"
                x:Name="SkippedBorder"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,10,0,0"
                Padding="10"
                Visibility="Collapsed">
            <TextBlock x:Name="SkippedTextBlock"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource WarningBrush}"
                       FontSize="{DynamicResource SmallFontSize}" />
        </Border>

        <!-- 目标状态选择 -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="目标状态："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <RadioButton x:Name="NotTraveledRadio"
                             Content="未出行"
                             GroupName="StatusGroup"
                             Margin="0,0,20,0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}" />
                <RadioButton x:Name="CompletedRadio"
                             Content="已完成"
                             GroupName="StatusGroup"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}" />
            </StackPanel>
        </Grid>

        <!-- 提示信息 -->
        <TextBlock Grid.Row="4"
                   Text="注意：已改签或已退票的车票无法通过此功能修改状态。"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="{DynamicResource SmallFontSize}"
                   TextWrapping="Wrap"
                   Margin="0,15,0,0" />

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Margin="0,0,10,0"
                    Click="OkButton_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>