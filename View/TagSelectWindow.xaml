<Window x:Class="GuiPiao.View.TagSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="选择标签"
        Height="Auto"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="请选择要筛选的标签"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15" />

        <!-- 标签列表 -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource ContentBackgroundBrush}"
                Padding="15"
                Margin="0,0,0,15">
            <ItemsControl x:Name="TagsItemsControl" ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TagBorder"
                                Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                CornerRadius="12"
                                Padding="12,6"
                                Margin="0,0,10,10"
                                Cursor="Hand"
                                Opacity="0.5"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                MouseLeftButtonDown="TagBorder_MouseLeftButtonDown">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{Binding TextColor, Converter={StaticResource StringToBrushConverter}}"
                                       FontSize="{DynamicResource BaseFontSize}" />
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="TagBorder" Property="Opacity" Value="1" />
                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Margin="0,0,10,0"
                    Click="OkButton_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
