<UserControl x:Class="GuiPiao.View.ExportSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:GuiPiao.Model"
             FontSize="{DynamicResource BaseFontSize}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 默认导出设置 -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 默认导出设置" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <!-- 默认格式 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="默认导出格式：" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding DefaultFormat}" SelectedValuePath="Tag" Margin="10,0,0,0">
                                <ComboBoxItem Content="Excel" Tag="{x:Static model:ExportFormatOption.Excel}" />
                                <ComboBoxItem Content="CSV" Tag="{x:Static model:ExportFormatOption.Csv}" />
                                <ComboBoxItem Content="PDF" Tag="{x:Static model:ExportFormatOption.Pdf}" />
                                <ComboBoxItem Content="图片" Tag="{x:Static model:ExportFormatOption.Image}" />
                            </ComboBox>
                        </StackPanel>

                        <!-- 默认保存路径 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认保存路径：" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox Grid.Column="1" Text="{Binding DefaultSavePath}" IsReadOnly="True" Margin="10,0,10,0" />
                            <Button Grid.Column="2" Content="📂 浏览" Command="{Binding BrowsePathCommand}" Style="{StaticResource StandardButtonStyle}" Padding="10,5" />
                        </Grid>

                        <!-- 文件名模板 -->
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="文件名模板：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox Width="200" Text="{Binding FileNameTemplate}" Margin="0,0,10,5" />
                            <TextBlock Text="可用变量：{日期} {时间} {车次}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <!-- 导出后操作 -->
                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Content="导出后自动打开文件" IsChecked="{Binding OpenAfterExport}" Margin="0,0,20,5" />
                            <CheckBox Content="显示导出成功提示" IsChecked="{Binding ShowSuccessMessage}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <!-- 分组导出 -->
                        <WrapPanel>
                            <CheckBox Content="按当前分组设置导出" IsChecked="{Binding EnableGroupExport}" ToolTip="启用后，Excel将按分组创建多个工作表，PDF将按分组显示" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Excel导出设置 -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📊 Excel导出设置" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="工作表名称：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox Width="150" Text="{Binding ExcelSheetName}" Margin="0,0,20,5" />
                            <CheckBox Content="包含列标题" IsChecked="{Binding ExcelIncludeHeader}" Margin="0,0,20,5" />
                            <CheckBox Content="自动调整列宽" IsChecked="{Binding ExcelAutoFitColumns}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel>
                            <TextBlock Text="日期格式：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="150" SelectedValue="{Binding ExcelDateFormat}" SelectedValuePath="Tag" Margin="0,0,20,5">
                                <ComboBoxItem Content="2024-01-15" Tag="{x:Static model:DateFormatOption.yyyyMMdd}" />
                                <ComboBoxItem Content="2024/01/15" Tag="{x:Static model:DateFormatOption.yyyyMMddSlash}" />
                                <ComboBoxItem Content="2024年01月15日" Tag="{x:Static model:DateFormatOption.yyyyMMddChinese}" />
                                <ComboBoxItem Content="01/15/2024" Tag="{x:Static model:DateFormatOption.MMddyyyy}" />
                            </ComboBox>
                            <TextBlock Text="金额格式：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding ExcelMoneyFormat}" SelectedValuePath="Tag" Margin="0,0,0,5">
                                <ComboBoxItem Content="523.50" Tag="{x:Static model:MoneyFormatOption.Yuan}" />
                                <ComboBoxItem Content="¥523.50" Tag="{x:Static model:MoneyFormatOption.YuanWithSymbol}" />
                                <ComboBoxItem Content="52350" Tag="{x:Static model:MoneyFormatOption.Fen}" />
                            </ComboBox>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- CSV导出设置 -->
                <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📄 CSV导出设置" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="编码格式：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding CsvEncoding}" SelectedValuePath="Tag" Margin="0,0,20,5">
                                <ComboBoxItem Content="UTF-8" Tag="{x:Static model:CsvEncodingOption.UTF8}" />
                                <ComboBoxItem Content="GBK(兼容Excel)" Tag="{x:Static model:CsvEncodingOption.GBK}" />
                                <ComboBoxItem Content="Unicode" Tag="{x:Static model:CsvEncodingOption.Unicode}" />
                            </ComboBox>
                            <TextBlock Text="分隔符：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="100" SelectedValue="{Binding CsvDelimiter}" SelectedValuePath="Tag" Margin="0,0,0,5">
                                <ComboBoxItem Content="逗号" Tag="{x:Static model:CsvDelimiterOption.Comma}" />
                                <ComboBoxItem Content="分号" Tag="{x:Static model:CsvDelimiterOption.Semicolon}" />
                                <ComboBoxItem Content="制表符" Tag="{x:Static model:CsvDelimiterOption.Tab}" />
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Content="包含列标题" IsChecked="{Binding CsvIncludeHeader}" Margin="0,0,20,5" />
                            <CheckBox Content="使用文本限定符(双引号)" IsChecked="{Binding CsvUseTextQualifier}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel>
                            <TextBlock Text="日期格式：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="150" SelectedValue="{Binding CsvDateFormat}" SelectedValuePath="Tag" Margin="0,0,20,5">
                                <ComboBoxItem Content="2024-01-15" Tag="{x:Static model:DateFormatOption.yyyyMMdd}" />
                                <ComboBoxItem Content="2024/01/15" Tag="{x:Static model:DateFormatOption.yyyyMMddSlash}" />
                                <ComboBoxItem Content="2024年01月15日" Tag="{x:Static model:DateFormatOption.yyyyMMddChinese}" />
                                <ComboBoxItem Content="01/15/2024" Tag="{x:Static model:DateFormatOption.MMddyyyy}" />
                            </ComboBox>
                            <TextBlock Text="金额格式：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding CsvMoneyFormat}" SelectedValuePath="Tag" Margin="0,0,0,5">
                                <ComboBoxItem Content="523.50" Tag="{x:Static model:MoneyFormatOption.Yuan}" />
                                <ComboBoxItem Content="¥523.50" Tag="{x:Static model:MoneyFormatOption.YuanWithSymbol}" />
                                <ComboBoxItem Content="52350" Tag="{x:Static model:MoneyFormatOption.Fen}" />
                            </ComboBox>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- PDF/图片导出设置 -->
                <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📑 PDF/图片导出设置" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="每页行数：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox MinWidth="60" Text="{Binding PdfRowsPerPage}" Margin="0,0,20,5" />
                            <TextBlock Text="纸张大小：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="80" SelectedValue="{Binding PdfPaperSize}" SelectedValuePath="Content" Margin="0,0,20,5">
                                <ComboBoxItem Content="A4" />
                                <ComboBoxItem Content="A5" />
                                <ComboBoxItem Content="Letter" />
                            </ComboBox>
                            <TextBlock Text="方向：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <RadioButton Content="纵向" GroupName="PdfOrientation" IsChecked="{Binding IsPdfPortrait}" Margin="0,0,10,5" />
                            <RadioButton Content="横向" GroupName="PdfOrientation" IsChecked="{Binding IsPdfLandscape}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="字体大小：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="8" Maximum="16" Value="{Binding PdfFontSize}" TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True" Margin="0,0,10,5" />
                            <TextBlock Text="{Binding PdfFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="25" Margin="0,0,0,5" />
                            <TextBlock Text="pt" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel>
                            <TextBlock Text="页边距(mm)：" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="上" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,2,5" />
                            <TextBox MinWidth="40" Text="{Binding PdfMarginTop}" Margin="0,0,0,5" />
                            <TextBlock Text="下" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,2,5" />
                            <TextBox MinWidth="40" Text="{Binding PdfMarginBottom}" Margin="0,0,0,5" />
                            <TextBlock Text="左" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,2,5" />
                            <TextBox MinWidth="40" Text="{Binding PdfMarginLeft}" Margin="0,0,0,5" />
                            <TextBlock Text="右" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,2,5" />
                            <TextBox MinWidth="40" Text="{Binding PdfMarginRight}" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 导出字段选择 -->
                <Border Grid.Row="4" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📋 导出字段选择" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        
                        <WrapPanel>
                            <CheckBox Content="票号" IsChecked="{Binding ExportTicketNumber}" Margin="0,0,20,10" />
                            <CheckBox Content="车次" IsChecked="{Binding ExportTrainNo}" Margin="0,0,20,10" />
                            <CheckBox Content="出发站" IsChecked="{Binding ExportDepartStation}" Margin="0,0,20,10" />
                            <CheckBox Content="到达站" IsChecked="{Binding ExportArriveStation}" Margin="0,0,20,10" />
                            <CheckBox Content="出发日期" IsChecked="{Binding ExportDepartDate}" Margin="0,0,20,10" />
                            <CheckBox Content="出发时间" IsChecked="{Binding ExportDepartTime}" Margin="0,0,20,10" />
                            <CheckBox Content="车厢号" IsChecked="{Binding ExportCoachNo}" Margin="0,0,20,10" />
                            <CheckBox Content="座位号" IsChecked="{Binding ExportSeatNo}" Margin="0,0,20,10" />
                            <CheckBox Content="席别" IsChecked="{Binding ExportSeatType}" Margin="0,0,20,10" />
                            <CheckBox Content="票价" IsChecked="{Binding ExportMoney}" Margin="0,0,20,10" />
                            <CheckBox Content="检票口" IsChecked="{Binding ExportCheckInLocation}" Margin="0,0,20,10" />
                            <CheckBox Content="标签" IsChecked="{Binding ExportTags}" Margin="0,0,20,10" />
                            <CheckBox Content="备注" IsChecked="{Binding ExportAdditionalInfo}" Margin="0,0,20,10" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 测试与预览 -->
                <Border Grid.Row="5" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🧪 测试与预览" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="👁️ 预览导出效果" Command="{Binding PreviewExportCommand}" Style="{StaticResource StandardButtonStyle}" Padding="15,6" Margin="0,0,10,0" />
                            <Button Content="📄 导出测试文件" Command="{Binding ExportTestCommand}" Style="{StaticResource StandardButtonStyle}" Padding="15,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 保存设置" Command="{Binding SaveSettingsCommand}" 
                        Padding="15,8" Margin="0,0,10,0" Style="{StaticResource StandardButtonStyle}" />
                <Button Content="🔄 恢复默认" Command="{Binding RestoreDefaultsCommand}" 
                        Padding="15,8" Style="{StaticResource StandardButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
