<Window x:Class="GuiPiao.View.TagManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GuiPiao.View"
        mc:Ignorable="d"
        Title="标签管理"
        Width="800"
        Height="450"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="标签管理"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15" />

        <!-- 搜索栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0"
                     x:Name="SearchTextBox"
                     Padding="8,4"
                     FontSize="{DynamicResource BaseFontSize}"
                     Background="{DynamicResource ContentBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" />
            
            <Button Grid.Column="1"
                    Content="搜索"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="60"
                    Margin="10,0,0,0"
                    Click="SearchButton_Click" />
            
            <Button Grid.Column="2"
                    Content="新建标签"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Margin="10,0,0,0"
                    Click="NewTagButton_Click" />
        </Grid>

        <!-- 标签列表 -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource ContentBackgroundBrush}">
            <DataGrid x:Name="TagsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="False"
                      GridLinesVisibility="Horizontal"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource NormalScrollBarStyle}"/>
                        </Style.Resources>
                    </Style>
                </DataGrid.Style>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}"/>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" CanUserSort="True" />
                    <DataGridTextColumn Header="标签名称" Binding="{Binding Name}" Width="180" CanUserSort="True" />
                    <DataGridTemplateColumn Header="颜色" Width="60" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="24"
                                        Height="16"
                                        CornerRadius="3"
                                        Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ToolTip="{Binding Color}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="180" CanUserSort="True" />
                    <DataGridTemplateColumn Header="默认" Width="50" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsDefault}"
                                          IsEnabled="False"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="操作" Width="*" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="编辑"
                                            Style="{StaticResource TableActionButtonStyle}"
                                            Margin="0,0,5,0"
                                            Click="EditButton_Click"
                                            Tag="{Binding}" />
                                    <Button Content="删除"
                                            Style="{StaticResource TableActionButtonStyle}"
                                            Click="DeleteButton_Click"
                                            Tag="{Binding}" />
                                    <Button Content="置顶"
                                            Style="{StaticResource TableActionButtonStyle}"
                                            Margin="5,0,0,0"
                                            Click="MoveTopButton_Click"
                                            Tag="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 提示说明 -->
        <TextBlock Grid.Row="3"
                   Text="提示：设为默认的标签会在新建车票时自动选中"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="{DynamicResource SmallFontSize}"
                   Margin="0,5,0,5" />

        <!-- 底部统计和关闭按钮 -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0"
                       x:Name="CountTextBlock"
                       Text="共 0 个标签"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource SmallFontSize}" />
            
            <Button Grid.Column="1"
                    Content="关闭"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
