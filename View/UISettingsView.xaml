<UserControl x:Class="GuiPiao.View.UISettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:GuiPiao.Model"
             xmlns:messages="clr-namespace:GuiPiao.Messages"
             FontSize="{DynamicResource BaseFontSize}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 票面预览显示设置 -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🎫 票面预览显示设置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="默认缩放：" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding DefaultZoom}" SelectedValuePath="Tag"
                                      Margin="0,0,20,0">
                                <ComboBoxItem Content="适应窗口" Tag="FitWindow" />
                                <ComboBoxItem Content="50%" Tag="50" />
                                <ComboBoxItem Content="75%" Tag="75" />
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="125%" Tag="125" />
                                <ComboBoxItem Content="150%" Tag="150" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                            </ComboBox>
                            <CheckBox Content="允许鼠标滚轮缩放" IsChecked="{Binding AllowMouseWheelZoom}"
                                      VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="显示亮度：" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="200" Minimum="50" Maximum="150" Value="{Binding DisplayBrightness}"
                                    TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True" />
                            <TextBlock Text="{Binding DisplayBrightness, StringFormat='{}{0}%'}"
                                       VerticalAlignment="Center" Margin="10,0,20,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="40" />
                            <CheckBox Content="票面居中显示" IsChecked="{Binding TicketCentered}" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Button Content="👁 测试预览效果" Command="{Binding TestTicketPreviewCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 主界面布局配置 -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📐 主界面布局配置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="左侧检索区宽度：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="175" Maximum="300" Value="{Binding LeftPanelWidth}"
                                    TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    IsEnabled="{Binding LeftPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding LeftPanelWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center"
                                     IsEnabled="{Binding LeftPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"
                                     LostFocus="NumericTextBox_LostFocus" Tag="130,300" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <CheckBox Content="锁定宽度" IsChecked="{Binding LeftPanelLocked}" VerticalAlignment="Center"
                                      Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="右侧日志面板宽度：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="180" Maximum="350" Value="{Binding RightPanelWidth}"
                                    TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    IsEnabled="{Binding RightPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding RightPanelWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center"
                                     IsEnabled="{Binding RightPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"
                                     LostFocus="NumericTextBox_LostFocus" Tag="180,350" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <CheckBox Content="锁定宽度" IsChecked="{Binding RightPanelLocked}" VerticalAlignment="Center"
                                      Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="底部行程列表高度：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="150" Maximum="400" Value="{Binding BottomPanelHeight}"
                                    TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    IsEnabled="{Binding BottomPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding BottomPanelHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center"
                                     IsEnabled="{Binding BottomPanelLocked, Converter={StaticResource InverseBooleanConverter}}"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"
                                     LostFocus="NumericTextBox_LostFocus" Tag="150,400" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <CheckBox Content="锁定高度" IsChecked="{Binding BottomPanelLocked}" VerticalAlignment="Center"
                                      Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="行程视图模式：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox Width="120"
                                      SelectedValue="{Binding CurrentTripListView, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag" Margin="0,0,20,5">
                                <ComboBoxItem Content="专业列表">
                                    <ComboBoxItem.Tag>
                                        <messages:ViewType>List</messages:ViewType>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="简洁卡片">
                                    <ComboBoxItem.Tag>
                                        <messages:ViewType>Card</messages:ViewType>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                            </ComboBox>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Button Content="💾 保存当前布局" Command="{Binding SaveLayoutCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,0" />
                            <Button Content="🔄 重置布局默认" Command="{Binding ResetLayoutCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 行程列表显示设置 -->
                <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📋 行程列表显示设置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="⚙️ 自定义列表字段" Command="{Binding CustomizeFieldsCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,5" />
                            <Button Content="🔄 重置列表默认" Command="{Binding ResetListDefaultsCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="默认分组：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox Width="140"
                                      SelectedValue="{Binding DefaultGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag" Margin="0,0,20,5">
                                <ComboBoxItem Content="不分组">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>None</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="按日期(日)">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>DateDay</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="按日期(月)">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>DateMonth</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="按车次">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>TrainNo</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="按出发站">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>Departure</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="按到达站">
                                    <ComboBoxItem.Tag>
                                        <model:GroupOption>Arrival</model:GroupOption>
                                    </ComboBoxItem.Tag>
                                </ComboBoxItem>
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Content="记住字段顺序" IsChecked="{Binding RememberColumnOrder}"
                                      VerticalAlignment="Center" Margin="0,0,20,5" />
                            <CheckBox Content="记住数据排序" IsChecked="{Binding RememberDataSort}"
                                      VerticalAlignment="Center" Margin="0,0,0,5" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="滚动条样式：" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="100" SelectedValue="{Binding ScrollbarStyle}" SelectedValuePath="Tag"
                                      Margin="0,0,0,5">
                                <ComboBoxItem Content="正常" Tag="Normal" />
                                <ComboBoxItem Content="精简" Tag="Minimal" />
                                <ComboBoxItem Content="悬停显示" Tag="Hover" />
                            </ComboBox>
                        </WrapPanel>

                        <CheckBox Content="鼠标悬停时显示操作按钮" IsChecked="{Binding ShowActionButtonsOnHover}"
                                  Margin="0,0,0,10" />

                        <TextBlock Text="选择要显示的操作按钮：" FontWeight="Bold" Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <WrapPanel Margin="0,0,0,5">
                            <CheckBox Content="👁 查看" IsChecked="{Binding ShowViewButton}" Margin="0,0,15,5" />
                            <CheckBox Content="✏️ 编辑" IsChecked="{Binding ShowEditButton}" Margin="0,0,15,5" />
                            <CheckBox Content="🔄 改签" IsChecked="{Binding ShowRescheduleButton}" Margin="0,0,15,5" />
                            <CheckBox Content="💰 退票" IsChecked="{Binding ShowRefundButton}" Margin="0,0,15,5" />
                            <CheckBox Content="🗑️ 删除" IsChecked="{Binding ShowDeleteButton}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <CheckBox Content="默认展开行程区域" IsChecked="{Binding IsTripListExpandedByDefault}" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>

                <!-- 卡片视图显示设置 -->
                <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🎴 卡片视图显示设置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <!-- 布局设置 -->
                        <TextBlock Text="布局设置：" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="每行卡片数：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox Width="80" SelectedValue="{Binding CardsPerRow}" SelectedValuePath="Tag"
                                      Margin="0,0,20,5">
                                <ComboBoxItem Content="自动" Tag="0" />
                                <ComboBoxItem Content="2" Tag="2" />
                                <ComboBoxItem Content="3" Tag="3" />
                                <ComboBoxItem Content="4" Tag="4" />
                                <ComboBoxItem Content="5" Tag="5" />
                            </ComboBox>
                        </WrapPanel>

                        <!-- 卡片宽度仅在自动模式下显示 -->
                        <WrapPanel Margin="0,0,0,8"
                                   Visibility="{Binding CardsPerRow, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter='0'}">
                            <TextBlock Text="卡片宽度：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="240" Maximum="320" Value="{Binding CardWidth}"
                                    TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding CardWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center" Tag="240,320" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </WrapPanel>

                        <!-- 固定列数模式提示 -->
                        <TextBlock Margin="0,0,0,8" FontSize="12" FontStyle="Italic"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Visibility="{Binding CardsPerRow, Converter={StaticResource InverseIntToVisibilityConverter}, ConverterParameter='0'}">
                            固定列数模式下，卡片宽度将根据容器自动计算
                        </TextBlock>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="卡片间距：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="4" Maximum="16" Value="{Binding CardSpacing}"
                                    TickFrequency="2" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding CardSpacing, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center" Tag="4,16" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="卡片圆角：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Width="150" Minimum="0" Maximum="16" Value="{Binding CardCornerRadius}"
                                    TickFrequency="2" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Margin="0,0,10,5" />
                            <TextBox MinWidth="50"
                                     Text="{Binding CardCornerRadius, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,5,5" VerticalAlignment="Center" Tag="0,16" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,15,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </WrapPanel>

                        <!-- 操作设置 -->
                        <TextBlock Text="操作设置：" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="右键菜单操作按钮：" Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Content="👁 查看" IsChecked="{Binding CardShowViewAction}" Margin="0,0,15,5" />
                            <CheckBox Content="✏️ 编辑" IsChecked="{Binding CardShowEditAction}" Margin="0,0,15,5" />
                            <CheckBox Content="🔄 改签" IsChecked="{Binding CardShowRescheduleAction}" Margin="0,0,15,5" />
                            <CheckBox Content="💰 退票" IsChecked="{Binding CardShowRefundAction}" Margin="0,0,15,5" />
                            <CheckBox Content="🗑️ 删除" IsChecked="{Binding CardShowDeleteAction}" Margin="0,0,0,5" />
                        </WrapPanel>

                        <!-- 批量操作 -->
                        <TextBlock Text="批量操作：" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <CheckBox Content="启用多选 (Ctrl+单击多选, Shift+连选)" IsChecked="{Binding CardEnableMultiSelect}"
                                  Margin="0,0,0,8" />

                        <StackPanel IsEnabled="{Binding CardEnableMultiSelect}" Margin="0,0,0,10">
                            <WrapPanel>
                                <CheckBox Content="👁 查看" IsChecked="{Binding CardBatchShowView}" Margin="0,0,15,5" />
                                <CheckBox Content="✏️ 编辑" IsChecked="{Binding CardBatchShowEdit}" Margin="0,0,15,5" />
                                <CheckBox Content="🔄 改签" IsChecked="{Binding CardBatchShowReschedule}"
                                          Margin="0,0,15,5" />
                                <CheckBox Content="💰 退票" IsChecked="{Binding CardBatchShowRefund}" Margin="0,0,15,5" />
                                <CheckBox Content="🗑️ 删除" IsChecked="{Binding CardBatchShowDelete}" Margin="0,0,0,5" />
                            </WrapPanel>
                        </StackPanel>

                        <!-- 外观效果 -->
                        <TextBlock Text="外观效果：" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="状态标签位置：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox Width="100" SelectedValue="{Binding CardStatusPosition}" SelectedValuePath="Tag"
                                      Margin="0,0,0,5">
                                <ComboBoxItem Content="右上角" Tag="TopRight" />
                                <ComboBoxItem Content="顶部居中" Tag="TopCenter" />
                                <ComboBoxItem Content="隐藏" Tag="Hidden" />
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,5">
                            <CheckBox Content="悬停时高亮边框" IsChecked="{Binding CardHoverHighlight}" Margin="0,0,20,5" />
                            <CheckBox Content="显示卡片阴影效果" IsChecked="{Binding CardShowShadow}" Margin="0,0,20,5" />
                            <CheckBox Content="卡片悬停放大效果" IsChecked="{Binding CardHoverScale}" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 日志面板显示设置 -->
                <Border Grid.Row="4" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📄 日志面板显示设置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="日志行高：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="100" SelectedValue="{Binding LogRowHeight}" SelectedValuePath="Tag"
                                      Margin="0,0,0,5">
                                <ComboBoxItem Content="紧凑" Tag="Compact" />
                                <ComboBoxItem Content="标准" Tag="Standard" />
                                <ComboBoxItem Content="宽松" Tag="Loose" />
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="信息颜色：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border Width="24" Height="16" Background="{Binding InfoColorBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="2" Margin="0,0,5,0" Cursor="Hand"
                                        MouseLeftButtonDown="InfoColorBorder_MouseLeftButtonDown">
                                    <Border.ToolTip>
                                        <TextBlock Text="点击选择颜色" />
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="警告颜色：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border Width="24" Height="16" Background="{Binding WarningColorBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="2" Margin="0,0,5,0" Cursor="Hand"
                                        MouseLeftButtonDown="WarningColorBorder_MouseLeftButtonDown">
                                    <Border.ToolTip>
                                        <TextBlock Text="点击选择颜色" />
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="错误颜色：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border Width="24" Height="16" Background="{Binding ErrorColorBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="2" Margin="0,0,5,0" Cursor="Hand"
                                        MouseLeftButtonDown="ErrorColorBorder_MouseLeftButtonDown">
                                    <Border.ToolTip>
                                        <TextBlock Text="点击选择颜色" />
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="致命颜色：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border Width="24" Height="16" Background="{Binding FatalColorBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="2" Margin="0,0,5,0" Cursor="Hand"
                                        MouseLeftButtonDown="FatalColorBorder_MouseLeftButtonDown">
                                    <Border.ToolTip>
                                        <TextBlock Text="点击选择颜色" />
                                    </Border.ToolTip>
                                </Border>
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel>
                            <CheckBox Content="显示时间戳" IsChecked="{Binding ShowTimestamp}" Margin="0,0,20,5" />
                            <CheckBox Content="显示模块来源" IsChecked="{Binding ShowModuleSource}" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 高级界面选项 -->
                <Border Grid.Row="6" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🔧 高级界面选项" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="DPI缩放适配：" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedValue="{Binding DpiScaling}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="跟随系统" Tag="System" />
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="125%" Tag="125" />
                                <ComboBoxItem Content="150%" Tag="150" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 保存设置" Command="{Binding SaveSettingsCommand}"
                        Padding="15,8" Margin="0,0,10,0" Style="{StaticResource StandardButtonStyle}" />
                <Button Content="🔄 恢复默认" Command="{Binding RestoreDefaultsCommand}"
                        Padding="15,8" Style="{StaticResource StandardButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>