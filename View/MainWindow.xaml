<Window x:Class="GuiPiao.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GuiPiao.View"
        xmlns:vm="clr-namespace:GuiPiao.ViewModel"
        xmlns:controls="clr-namespace:GuiPiao.Controls"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="火车票管理系统 - v1.0.0"
        Height="700"
        Width="1000"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <DockPanel Background="{DynamicResource ContentBackgroundBrush}">

        <Menu DockPanel.Dock="Top" Background="{DynamicResource MenuBackgroundBrush}">
            <!-- 1. 存储(S) -->
            <MenuItem Header="存储(_S)">
                <MenuItem Header="数据导入">
                    <MenuItem Header="从Excel/CSV导入" Command="{Binding StorageMenuCommandCommand}"
                              CommandParameter="Import" />
                </MenuItem>
                <Separator />
                <MenuItem Header="数据库操作">
                    <MenuItem Header="全量备份数据库" Command="{Binding StorageMenuCommandCommand}"
                              CommandParameter="BackupFull" />
                    <MenuItem Header="增量备份数据库" Command="{Binding StorageMenuCommandCommand}"
                              CommandParameter="BackupIncremental" />
                    <MenuItem Header="恢复数据库" Command="{Binding StorageMenuCommandCommand}" CommandParameter="Restore" />
                    <Separator />
                    <MenuItem Header="打开存储目录" Command="{Binding StorageMenuCommandCommand}"
                              CommandParameter="OpenStorageDir" />
                </MenuItem>
                <Separator />
                <MenuItem Header="数据完整性校验" Command="{Binding StorageMenuCommandCommand}" CommandParameter="VerifyData" />
                <MenuItem Header="清空票务记录" Command="{Binding StorageMenuCommandCommand}"
                          CommandParameter="ClearAllTickets" />
                <Separator />
                <MenuItem Header="退出" Command="{Binding StorageMenuCommandCommand}" CommandParameter="Exit" />
            </MenuItem>

            <!-- 2. 票务(O) -->
            <MenuItem Header="票务(_O)">
                <MenuItem Header="新增票务记录" Command="{Binding NewTicketRecordCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="OCR识别车票" Command="{Binding OcrRecognizeTicketCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="编辑选中票务" Command="{Binding EditSelectedTicketCommand}" InputGestureText="Ctrl+E" />
                <MenuItem Header="删除选中票务" Command="{Binding DeleteSelectedTicketCommand}" InputGestureText="Del" />
                <Separator />
                <MenuItem Header="批量操作">
                    <MenuItem Header="批量修改状态" Click="BatchUpdateStatus_Click" />
                    <MenuItem Header="批量更改标签" Click="BatchUpdateTag_Click" />
                    <MenuItem Header="批量删除" Click="BatchDelete_Click" />
                </MenuItem>
                <MenuItem Header="标签管理">
                    <MenuItem Header="新建标签" Click="NewTag_Click" />
                    <MenuItem Header="管理标签" Click="ManageTags_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="票面预览" Command="{Binding TicketPreviewCommand}" InputGestureText="Ctrl+P" />
            </MenuItem>

            <!-- 3. 行程管理(M) -->
            <MenuItem Header="行程管理(_M)">
                <MenuItem Header="高级筛选">
                    <MenuItem Header="按时间筛选">
                        <MenuItem Header="本年度" Command="{Binding TripMenuCommandCommand}"
                                  CommandParameter="FilterThisYear" />
                        <MenuItem Header="上年度" Command="{Binding TripMenuCommandCommand}"
                                  CommandParameter="FilterLastYear" />
                        <MenuItem Header="自定义时间区间" Command="{Binding TripMenuCommandCommand}"
                                  CommandParameter="FilterCustomDate" />
                        <Separator />
                        <MenuItem Header="未出行行程" Command="{Binding TripMenuCommandCommand}"
                                  CommandParameter="FilterUpcoming" />
                    </MenuItem>
                    <MenuItem Header="按车次/站点筛选" Command="{Binding TripMenuCommandCommand}"
                              CommandParameter="FilterTrainStation" />
                    <MenuItem Header="按标签筛选" Command="{Binding TripMenuCommandCommand}" CommandParameter="FilterByTag" />
                    <Separator />
                    <MenuItem Header="取消筛选" Command="{Binding TripMenuCommandCommand}" CommandParameter="ClearFilter" />
                </MenuItem>
                <Separator />
                <MenuItem Header="车票地图" Command="{Binding OpenTicketMapCommand}" InputGestureText="Ctrl+M" />
                <MenuItem Header="仪表盘统计">
                    <MenuItem Header="统计配置" Command="{Binding TripMenuCommandCommand}" CommandParameter="StatsConfig" />
                    <MenuItem Header="刷新统计" Command="{Binding TripMenuCommandCommand}" CommandParameter="RefreshStats"
                              InputGestureText="F5" />
                    <MenuItem Header="导出统计图表" Command="{Binding TripMenuCommandCommand}" CommandParameter="ExportChart" />
                </MenuItem>
                <Separator />
                <MenuItem Header="视图配置">
                    <MenuItem Header="专业列表视图" Command="{Binding TripMenuCommandCommand}" CommandParameter="ViewList" />
                    <MenuItem Header="简洁卡片视图" Command="{Binding TripMenuCommandCommand}" CommandParameter="ViewCard" />
                    <MenuItem Header="自定义显示列" Command="{Binding TripMenuCommandCommand}"
                              CommandParameter="ViewCustomColumns" />
                </MenuItem>
                <MenuItem Header="刷新行程" Command="{Binding TripMenuCommandCommand}" CommandParameter="RefreshList"
                          InputGestureText="F5" />
            </MenuItem>

            <!-- 4. 工具集(T) -->
            <MenuItem Header="工具集(_T)">
                <Separator />
                <MenuItem Header="数据工具">
                    <MenuItem Header="票务数据校验" Command="{Binding ToolsMenuCommandCommand}" CommandParameter="DataVerify" />
                    <MenuItem Header="数据库碎片整理" Command="{Binding ToolsMenuCommandCommand}" CommandParameter="DbCompact" />
                    <Separator />
                    <MenuItem Header="日志管理" Command="{Binding OpenLogManagerCommand}" InputGestureText="Ctrl+L" />
                </MenuItem>
                <MenuItem Header="数据清理" Command="{Binding ToolsMenuCommandCommand}" CommandParameter="DataClean" />
                <Separator />
                <MenuItem Header="备份/恢复数据库" Command="{Binding BackupRestoreDatabaseCommand}" />
            </MenuItem>

            <!-- 5. 配置(P) -->
            <MenuItem Header="配置(_P)">
                <MenuItem Header="系统设置..." Command="{Binding OpenSettingsCommand}" InputGestureText="Ctrl+," />
                <Separator />
                <MenuItem Header="日志设置" Command="{Binding OpenSettingsCommand}" CommandParameter="Log" />
                <MenuItem Header="数据库配置" Command="{Binding OpenSettingsCommand}" CommandParameter="Database" />
                <MenuItem Header="界面配置" Command="{Binding OpenSettingsCommand}" CommandParameter="UI" />
                <MenuItem Header="OCR配置" Command="{Binding OpenSettingsCommand}" CommandParameter="OCR" />
            </MenuItem>

            <!-- 6. 帮助与信息(H) -->
            <MenuItem Header="帮助与信息(_H)">
                <MenuItem Header="帮助文档" Command="{Binding HelpMenuCommandCommand}" CommandParameter="HelpDoc" />
                <MenuItem Header="使用手册" Command="{Binding HelpMenuCommandCommand}" CommandParameter="Manual" />
                <Separator />
                <MenuItem Header="关于系统" Command="{Binding HelpMenuCommandCommand}" CommandParameter="About" />
                <MenuItem Header="检查更新" Command="{Binding HelpMenuCommandCommand}" CommandParameter="CheckUpdate" />
            </MenuItem>
        </Menu>


        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🟢 " FontSize="{DynamicResource SmallFontSize}" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource SmallFontSize}" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="车票：" FontSize="{DynamicResource SmallFontSize}" />
                    <TextBlock Text="{Binding TotalItems}" FontSize="{DynamicResource SmallFontSize}" />
                    <TextBlock Text=" 条" FontSize="{DynamicResource SmallFontSize}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>


        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200" />
                <!-- 底部分割条行：锁定时为0，解锁时为5 -->
                <RowDefinition Height="{Binding BottomSplitterHeight}" />
                <RowDefinition Height="{Binding BottomRowHeight}" MinHeight="150" />
            </Grid.RowDefinitions>

            <!-- 上部区域：高级检索区 + 仪表盘 + 日志面板 -->
            <Grid x:Name="TopGrid" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <!-- 左侧检索区：使用星号宽度让GridSplitter可以调整 -->
                    <ColumnDefinition Width="{Binding LeftColumnWidth}" MinWidth="160" MaxWidth="800" />
                    <!-- 左侧分割条列：锁定时为0，解锁时为5 -->
                    <ColumnDefinition Width="{Binding LeftSplitterWidth}" />
                    <!-- 中间仪表盘：最小150px -->
                    <ColumnDefinition Width="*" MinWidth="150" />
                    <!-- 右侧分割条列：锁定时为0，解锁时为5 -->
                    <ColumnDefinition Width="{Binding RightSplitterWidth}" />
                    <!-- 右侧日志面板：使用星号宽度让GridSplitter可以调整 -->
                    <ColumnDefinition Width="{Binding RightColumnWidth}" MinWidth="200" MaxWidth="800" />
                </Grid.ColumnDefinitions>

                <!-- 左侧分割条 -->
                <GridSplitter x:Name="LeftSplitter" Grid.Column="1" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent" ShowsPreview="False"
                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                              Visibility="{Binding LeftSplitterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              DragCompleted="LeftSplitter_DragCompleted"
                              DragDelta="LeftSplitter_DragDelta" />

                <!-- 右侧分割条 -->
                <GridSplitter x:Name="RightSplitter" Grid.Column="3" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent" ShowsPreview="False"
                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                              Visibility="{Binding RightSplitterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              DragCompleted="RightSplitter_DragCompleted"
                              DragDelta="RightSplitter_DragDelta" />

                <!-- 左侧：高级检索区和快捷功能区 -->
                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- 高级检索区 -->
                            <Border Background="{DynamicResource PanelBackgroundBrush}" Margin="10"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="🔍 高级检索区" FontSize="{DynamicResource LargeFontSize}"
                                               FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
                                    <StackPanel>
                                        <!-- 出发站 -->
                                        <WrapPanel Margin="0,0,0,5">
                                            <TextBlock Text="出发站：" VerticalAlignment="Center" Margin="0,0,5,5"
                                                       FontSize="{DynamicResource BaseFontSize}" />
                                            <controls:AutoCompleteTextBox Text="{Binding DepartStation}"
                                                                          Suggestions="{Binding DepartStationSuggestions}"
                                                                          IsDropDownOpen="{Binding IsDepartStationDropDownOpen}"
                                                                          TextChangedCommand="{Binding DepartStationTextChangedCommand}"
                                                                          SelectItemCommand="{Binding SelectDepartStationCommand}"
                                                                          MinWidth="100" Margin="0,0,0,5" />
                                        </WrapPanel>

                                        <!-- 到达站 -->
                                        <WrapPanel Margin="0,0,0,5">
                                            <TextBlock Text="到达站：" VerticalAlignment="Center" Margin="0,0,5,5"
                                                       FontSize="{DynamicResource BaseFontSize}" />
                                            <controls:AutoCompleteTextBox Text="{Binding ArriveStation}"
                                                                          Suggestions="{Binding ArriveStationSuggestions}"
                                                                          IsDropDownOpen="{Binding IsArriveStationDropDownOpen}"
                                                                          TextChangedCommand="{Binding ArriveStationTextChangedCommand}"
                                                                          SelectItemCommand="{Binding SelectArriveStationCommand}"
                                                                          MinWidth="100" Margin="0,0,0,5" />
                                        </WrapPanel>

                                        <!-- 车次 -->
                                        <WrapPanel Margin="0,0,0,5">
                                            <TextBlock Text="车次：" VerticalAlignment="Center" Margin="0,0,5,5"
                                                       FontSize="{DynamicResource BaseFontSize}" />
                                            <Grid MinWidth="100" Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding TrainNoPrefixes}"
                                                          SelectedItem="{Binding SelectedTrainNoPrefix}"
                                                          Width="60"
                                                          FontSize="{DynamicResource BaseFontSize}"
                                                          Padding="4,2"
                                                          MinHeight="24" />
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding TrainNoNumber}"
                                                         IsEnabled="{Binding IsTrainNoNumberEnabled}"
                                                         FontSize="{DynamicResource BaseFontSize}"
                                                         Padding="4,2"
                                                         MinHeight="24" />
                                            </Grid>
                                        </WrapPanel>

                                        <!-- 日期范围 -->
                                        <WrapPanel Margin="0,0,0,5">
                                            <TextBlock Text="日期范围：" VerticalAlignment="Center" Margin="0,0,5,5"
                                                       FontSize="{DynamicResource BaseFontSize}" />
                                            <ComboBox Text="{Binding DateRange}" MinWidth="100" Margin="0,0,0,5"
                                                      FontSize="{DynamicResource BaseFontSize}">
                                                <ComboBoxItem>今年</ComboBoxItem>
                                                <ComboBoxItem>去年</ComboBoxItem>
                                                <ComboBoxItem>最近3个月</ComboBoxItem>
                                                <ComboBoxItem>最近6个月</ComboBoxItem>
                                            </ComboBox>
                                        </WrapPanel>

                                        <!-- 状态 -->
                                        <WrapPanel Margin="0,0,0,5">
                                            <TextBlock Text="状态：" VerticalAlignment="Center" Margin="0,0,5,5"
                                                       FontSize="{DynamicResource BaseFontSize}" />
                                            <ComboBox Text="{Binding Status}" MinWidth="100" Margin="0,0,0,5"
                                                      FontSize="{DynamicResource BaseFontSize}">
                                                <ComboBoxItem>全部</ComboBoxItem>
                                                <ComboBoxItem>未出行</ComboBoxItem>
                                                <ComboBoxItem>已完成</ComboBoxItem>
                                            </ComboBox>
                                        </WrapPanel>

                                        <!-- 按钮 -->
                                        <WrapPanel HorizontalAlignment="Right" Margin="0,10,0,0">
                                            <Button Content="🔎" ToolTip="检索" Command="{Binding SearchCommandCommand}"
                                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,5"
                                                    MinWidth="40" Padding="4,2" FontSize="12" />
                                            <Button Content="🗑️" ToolTip="清空条件"
                                                    Command="{Binding ClearConditionCommandCommand}"
                                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,0,5"
                                                    MinWidth="40" Padding="4,2" FontSize="12" />
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 快捷功能区 -->
                            <Border Background="{DynamicResource PanelBackgroundBrush}" Margin="10">
                                <StackPanel>
                                    <TextBlock Text="📌 快捷功能区" FontSize="{DynamicResource LargeFontSize}"
                                               FontWeight="Bold" Margin="0,10,0,10" TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Content="🆕" ToolTip="新增" Command="{Binding NewTicketRecordCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                        <Button Content="🔍" ToolTip="OCR识别"
                                                Command="{Binding OcrRecognizeTicketCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                        <Button Content="🗺️" ToolTip="地图" Command="{Binding OpenTicketMapCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                        <Button Content="🎫" ToolTip="预览" Command="{Binding TicketPreviewCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                        <Button Content="🔐" ToolTip="备份"
                                                Command="{Binding BackupRestoreDatabaseCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,4,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                        <Button Content="⚙️" ToolTip="配置" Command="{Binding SystemConfigCommand}"
                                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,0,4"
                                                MinWidth="40" Padding="4,2" FontSize="12" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 中间：仪表盘 -->
                <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <TextBlock Grid.Row="0" Text="📊 仪表盘"
                                   FontSize="{DynamicResource LargeFontSize}"
                                   FontWeight="Bold"
                                   Margin="10,10,10,5"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />

                        <!-- 图表区域 -->
                        <Grid Grid.Row="1" Margin="5,0">
                            <!-- 正常模式：图表列表 -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsFullscreenMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <Grid>
                                    <!-- 图表列表 - 使用Grid布局支持复杂布局 -->
                                    <ItemsControl x:Name="DashboardItemsControl"
                                                  ItemsSource="{Binding DashboardCharts}"
                                                  AllowDrop="True"
                                                  PreviewMouseLeftButtonDown="DashboardItemsControl_PreviewMouseLeftButtonDown"
                                                  MouseMove="DashboardItemsControl_MouseMove"
                                                  DragOver="DashboardItemsControl_DragOver"
                                                  Drop="DashboardItemsControl_Drop">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid x:Name="DashboardGrid" IsItemsHost="True">
                                                    <!-- 行列定义将通过代码动态生成 -->
                                                </Grid>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Grid.Row" Value="{Binding Card.GridRow, Mode=OneWay}" />
                                                <Setter Property="Grid.Column"
                                                        Value="{Binding Card.GridColumn, Mode=OneWay}" />
                                                <Setter Property="Grid.RowSpan"
                                                        Value="{Binding Card.GridRowSpan, Mode=OneWay}" />
                                                <Setter Property="Grid.ColumnSpan"
                                                        Value="{Binding Card.GridColumnSpan, Mode=OneWay}" />
                                                <Setter Property="Margin"
                                                        Value="{Binding Path=DataContext.DashboardConfig.CardSpacing, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource IntToThicknessConverter}}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <local:DashboardChartView DataContext="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 空状态提示 -->
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding HasDashboardCharts, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center"
                                                   Margin="0,0,0,10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="暂无图表" FontSize="{DynamicResource LargeFontSize}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,0,0,5"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="点击下方「统计配置」添加一个" FontSize="{DynamicResource BaseFontSize}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>

                            <!-- 全屏模式覆盖层 - 覆盖整个仪表盘区域 -->
                            <Border Grid.RowSpan="3"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    Visibility="{Binding IsFullscreenMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Panel.ZIndex="100">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 标题栏 -->
                                    <Grid Grid.Row="0" Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FullscreenChart.Title}"
                                                   FontSize="{DynamicResource TitleFontSize}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <Button Grid.Column="1"
                                                Content="关闭"
                                                Command="{Binding ExitFullscreenCommand}"
                                                Style="{StaticResource StandardButtonStyle}"
                                                MinWidth="60"
                                                ToolTip="关闭全屏" />
                                    </Grid>

                                    <!-- 全屏图表显示区域 -->
                                    <ContentControl Grid.Row="1"
                                                    Content="{Binding FullscreenChart}"
                                                    Margin="20,0"
                                                    VerticalAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Stretch">
                                                    <!-- 文本列表 -->
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  Visibility="{Binding IsTextList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <ItemsControl ItemsSource="{Binding ChartData.TextListItems}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                                                            BorderThickness="0,0,0,1"
                                                                            Padding="8,4">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0"
                                                                                    Text="{Binding Label}"
                                                                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                            <TextBlock Grid.Column="1"
                                                                                    Text="{Binding Value}"
                                                                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>

                                                    <!-- 饼图 -->
                                                    <lvc:PieChart Series="{Binding Series}"
                                                                  Background="Transparent"
                                                                  IsHitTestVisible="True"
                                                                  TooltipPosition="{Binding PieTooltipPosition}"
                                                                  TooltipTextPaint="{Binding TooltipTextPaint}"
                                                                  TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                                                  TooltipTextSize="{Binding TooltipTextSize}"
                                                                  AnimationsSpeed="{Binding AnimationSpeed}"
                                                                  EasingFunction="{Binding AnimationEasingFunction}"
                                                                  Visibility="{Binding IsPieChart, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                    <!-- 柱状图/条形图/折线图 -->
                                                    <lvc:CartesianChart Series="{Binding Series}"
                                                                        XAxes="{Binding XAxes}"
                                                                        YAxes="{Binding YAxes}"
                                                                        TooltipPosition="{Binding TooltipPosition}"
                                                                        TooltipTextPaint="{Binding TooltipTextPaint}"
                                                                        TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                                                        TooltipTextSize="{Binding TooltipTextSize}"
                                                                        AnimationsSpeed="{Binding AnimationSpeed}"
                                                                        EasingFunction="{Binding AnimationEasingFunction}"
                                                                        Visibility="{Binding IsCartesianChart, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>

                                    <!-- 底部导航栏 -->
                                    <Grid Grid.Row="2" Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Content="◀"
                                                Command="{Binding NavigateToPreviousChartCommand}"
                                                Style="{StaticResource StandardButtonStyle}"
                                                Width="50"
                                                Height="30"
                                                FontSize="16"
                                                IsEnabled="{Binding CanNavigatePrevious}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FullscreenIndicator}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{DynamicResource BaseFontSize}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                                        <Button Grid.Column="2"
                                                Content="▶"
                                                Command="{Binding NavigateToNextChartCommand}"
                                                Style="{StaticResource StandardButtonStyle}"
                                                Width="50"
                                                Height="30"
                                                FontSize="16"
                                                IsEnabled="{Binding CanNavigateNext}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 操作按钮 -->
                        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="10">
                            <Button Content="📝 统计配置"
                                    Command="{Binding StatisticsConfigCommand}"
                                    Style="{StaticResource StandardButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="OnStatisticsConfigClick" />
                            <Button Content="🔄 刷新统计"
                                    Command="{Binding RefreshStatisticsCommand}"
                                    IsEnabled="{Binding Dashboard.HasDashboardCharts}"
                                    Style="{StaticResource StandardButtonStyle}"
                                    Click="OnRefreshStatisticsClick" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- 右侧：日志面板 -->
                <Border Grid.Column="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" Margin="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="📜 日志面板" FontSize="{DynamicResource LargeFontSize}" FontWeight="Bold"
                                       TextWrapping="Wrap" />
                        </Border>
                        <DataGrid x:Name="LogDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                                  ItemsSource="{Binding LogItems}"
                                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{StaticResource ThemedDataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="TimeColumn" Header="时间" Width="Auto"
                                                    Binding="{Binding Time}" />
                                <DataGridTemplateColumn Header="级别" Width="Auto" MinWidth="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LevelDisplay}" Foreground="{Binding LevelColor}"
                                                       FontWeight="Bold" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="ModuleColumn" Header="来源" Width="Auto"
                                                    Binding="{Binding Module}" />
                                <DataGridTextColumn Header="内容" Width="*" MinWidth="80" Binding="{Binding Content}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="10">
                            <Button Content="📤 导出" Command="{Binding ExportLogCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" MinWidth="60" />
                            <Button Content="🗑️ 清空" Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,0,5" MinWidth="60" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 底部分割条 -->
            <GridSplitter x:Name="BottomSplitter" Grid.Row="1" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          Visibility="{Binding BottomSplitterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                          DragCompleted="BottomSplitter_DragCompleted"
                          DragDelta="BottomSplitter_DragDelta" />

            <!-- 下部区域：行程列表区 -->
            <Border x:Name="TripListBorder" Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" Padding="10,8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Cursor="Hand"
                            MouseLeftButtonUp="Border_MouseLeftButtonUp">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding TripList.SectionTitle}" FontSize="{DynamicResource LargeFontSize}"
                                       FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="2" Text="{Binding CollapseButtonContent}"
                                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,10,0" FontSize="{DynamicResource BaseFontSize}" />
                        </Grid>
                    </Border>

                    <!-- DataGrid区域 -->
                    <DataGrid x:Name="TripDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding TripItemsView}"
                              SelectedItem="{Binding SelectedTripItem}"
                              SelectionMode="Extended"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Stretch"
                              MouseDoubleClick="TripDataGrid_DoubleClick"
                              ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource ThemedDataGridCellStyle}"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              Loaded="TripDataGrid_Loaded"
                              Sorting="TripDataGrid_Sorting"
                              Visibility="{Binding IsDataGridVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Style.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource NormalScrollBarStyle}" />
                                </Style.Resources>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TripItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Hidden" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridRow">
                                            <Grid>
                                                <Border x:Name="DGR_Border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        SnapsToDevicePixels="True">
                                                    <SelectiveScrollingGrid>
                                                        <SelectiveScrollingGrid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </SelectiveScrollingGrid.ColumnDefinitions>
                                                        <SelectiveScrollingGrid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </SelectiveScrollingGrid.RowDefinitions>
                                                        <DataGridCellsPresenter Grid.Column="1"
                                                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                        <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1"
                                                                SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                Visibility="{TemplateBinding DetailsVisibility}" />
                                                    </SelectiveScrollingGrid>
                                                </Border>
                                                <!-- 操作按钮容器 - 悬浮在行右侧上方 -->
                                                <StackPanel x:Name="ActionButtonsPanel"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"
                                                            Panel.ZIndex="100">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}"
                                                                    Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Opacity" Value="1" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.ShowActionButtonsOnHover, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                                                    Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Opacity" Value="1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="4,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="👁"
                                                                    ToolTip="查看"
                                                                    Style="{StaticResource TableActionButtonStyle}"
                                                                    Margin="2,0"
                                                                    Visibility="{Binding DataContext.Layout.ShowViewButton, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Click="ViewButton_Click"
                                                                    Tag="{Binding}" />
                                                            <Button Content="✏️"
                                                                    ToolTip="编辑"
                                                                    Style="{StaticResource TableActionButtonStyle}"
                                                                    Margin="2,0"
                                                                    Visibility="{Binding DataContext.Layout.ShowEditButton, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Click="EditButton_Click"
                                                                    Tag="{Binding}" />
                                                            <Button Content="🔄"
                                                                    ToolTip="改签"
                                                                    Style="{StaticResource TableActionButtonStyle}"
                                                                    Margin="2,0"
                                                                    Visibility="{Binding DataContext.Layout.ShowRescheduleButton, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Click="RescheduleButton_Click"
                                                                    Tag="{Binding}" />
                                                            <Button Content="💰"
                                                                    ToolTip="退票"
                                                                    Style="{StaticResource TableActionButtonStyle}"
                                                                    Margin="2,0"
                                                                    Visibility="{Binding DataContext.Layout.ShowRefundButton, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Click="RefundButton_Click"
                                                                    Tag="{Binding}" />
                                                            <Button Content="🗑️"
                                                                    ToolTip="删除"
                                                                    Style="{StaticResource TableActionButtonStyle}"
                                                                    Margin="2,0"
                                                                    Visibility="{Binding DataContext.Layout.ShowDeleteButton, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Click="DeleteButton_Click"
                                                                    Tag="{Binding}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True"
                                                              Background="{DynamicResource PanelBackgroundBrush}"
                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                              BorderBrush="{DynamicResource BorderBrush}"
                                                              BorderThickness="0,0,0,1">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                <TextBlock
                                                                    Text="{Binding ItemCount, StringFormat=' ({0}项)'}"
                                                                    Margin="5,0,0,0"
                                                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                    </DataGrid>

                    <!-- 卡片视图 -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding TripList.IsCardViewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 批量操作工具栏 -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="10,5"
                                Visibility="{Binding TripList.HasSelectedItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="已选中：" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding TripList.SelectedItemsCount}" VerticalAlignment="Center" Margin="0,0,20,0"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" />
                                <Button Content="👁 查看" Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0"
                                        Visibility="{Binding Layout.CardBatchShowView, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BatchViewButton_Click" />
                                <Button Content="✏️ 编辑" Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0"
                                        Visibility="{Binding Layout.CardBatchShowEdit, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BatchEditButton_Click" />
                                <Button Content="🔄 改签" Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0"
                                        Visibility="{Binding Layout.CardBatchShowReschedule, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BatchRescheduleButton_Click" />
                                <Button Content="💰 退票" Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0"
                                        Visibility="{Binding Layout.CardBatchShowRefund, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BatchRefundButton_Click" />
                                <Button Content="🗑️ 删除" Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0"
                                        Visibility="{Binding Layout.CardBatchShowDelete, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BatchDeleteButton_Click" />
                                <Button Content="清除选择" Style="{StaticResource StandardButtonStyle}" Click="ClearCardSelection_Click" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding TripItemsView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <local:CardViewPanel 
                                        CardsPerRow="{Binding DataContext.Layout.CardsPerRow, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                        CardWidth="{Binding DataContext.Layout.CardWidth, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                        CardSpacing="{Binding DataContext.Layout.CardSpacing, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding DataContext.Layout.CardWidth, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                            MaxWidth="{Binding DataContext.Layout.CardWidth, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                            Margin="{Binding DataContext.Layout.CardMargin, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            CornerRadius="{Binding DataContext.Layout.CardCornerRadius, RelativeSource={RelativeSource AncestorType=local:MainWindow}}"
                                            Tag="{Binding}"
                                            MouseLeftButtonDown="CardViewBorder_MouseLeftButtonDown"
                                            MouseLeftButtonUp="CardViewBorder_MouseLeftButtonUp">
                                        <Border.ContextMenu>
                                            <ContextMenu Background="{DynamicResource PanelBackgroundBrush}"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                         BorderThickness="1"
                                                         FontSize="{DynamicResource BaseFontSize}"
                                                         Visibility="{Binding DataContext.Layout.IsCardContextMenuEnabled, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <MenuItem Header="👁 查看"
                                                          Click="CardViewMenuItem_Click"
                                                          Tag="View"
                                                          Style="{StaticResource ContextMenuItemStyle}"
                                                          Visibility="{Binding DataContext.Layout.CardShowViewAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <MenuItem Header="✏️ 编辑"
                                                          Click="CardViewMenuItem_Click"
                                                          Tag="Edit"
                                                          Style="{StaticResource ContextMenuItemStyle}"
                                                          Visibility="{Binding DataContext.Layout.CardShowEditAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Separator Background="{DynamicResource BorderBrush}"
                                                           Visibility="{Binding DataContext.Layout.CardShowRescheduleAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <MenuItem Header="🔄 改签"
                                                          Click="CardViewMenuItem_Click"
                                                          Tag="Reschedule"
                                                          Style="{StaticResource ContextMenuItemStyle}"
                                                          Visibility="{Binding DataContext.Layout.CardShowRescheduleAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <MenuItem Header="💰 退票"
                                                          Click="CardViewMenuItem_Click"
                                                          Tag="Refund"
                                                          Style="{StaticResource ContextMenuItemStyle}"
                                                          Visibility="{Binding DataContext.Layout.CardShowRefundAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Separator Background="{DynamicResource BorderBrush}"
                                                           Visibility="{Binding DataContext.Layout.CardShowDeleteAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <MenuItem Header="🗑️ 删除"
                                                          Click="CardViewMenuItem_Click"
                                                          Tag="Delete"
                                                          Style="{StaticResource ContextMenuItemStyle}"
                                                          Visibility="{Binding DataContext.Layout.CardShowDeleteAction, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.Layout.CardHoverHighlight, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="True" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.Layout.CardShowShadow, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="True" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect ShadowDepth="4" BlurRadius="12" Opacity="0.4" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.Layout.CardHoverScale, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="True" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Panel.ZIndex" Value="99" />
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect ShadowDepth="6" BlurRadius="16" Opacity="0.5" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 顶部：车次和状态 -->
                                            <Grid Grid.Row="0" Margin="12,10,12,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TrainNo}"
                                                           FontSize="{DynamicResource LargeFontSize}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <Border Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Setter Property="Grid.Column" Value="1" />
                                                            <Setter Property="Grid.ColumnSpan" Value="1" />
                                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                                            <Setter Property="VerticalAlignment" Value="Center" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.Layout.CardStatusPosition, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="Hidden">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.Layout.CardStatusPosition, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="TopCenter">
                                                                    <Setter Property="Grid.Column" Value="0" />
                                                                    <Setter Property="Grid.ColumnSpan" Value="2" />
                                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding StatusDisplay}"
                                                               FontSize="{DynamicResource SmallFontSize}"
                                                               Foreground="{DynamicResource AccentTextBrush}" />
                                                </Border>
                                            </Grid>

                                            <!-- 中间：站点和箭头 -->
                                            <Grid Grid.Row="1" Margin="12,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DepartStation}"
                                                               FontSize="{DynamicResource BaseFontSize}"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding DepartTime}"
                                                               FontSize="{DynamicResource SmallFontSize}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="→"
                                                           FontSize="20"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0" />
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding ArriveStation}"
                                                               FontSize="{DynamicResource BaseFontSize}"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding ArriveTime}"
                                                               FontSize="{DynamicResource SmallFontSize}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- 标准/详细/完整模式：日期、席别 -->
                                            <Grid Grid.Row="2" Margin="12,4"
                                                  Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Standard|Detailed|Full'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DepartDate, Converter={StaticResource DateFormatConverter}}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SeatType}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </Grid>

                                            <!-- 详细/完整模式：车厢号、座位号、检票口 -->
                                            <Grid Grid.Row="3" Margin="12,4"
                                                  Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Detailed|Full'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding CoachNo, StringFormat='车厢: {0}'}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Visibility="{Binding CoachNo, Converter={StaticResource StringToVisibilityConverter}}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SeatNo, StringFormat='座位: {0}'}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding SeatNo, Converter={StaticResource StringToVisibilityConverter}}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CheckInLocation, StringFormat='检票: {0}'}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"
                                                           Visibility="{Binding CheckInLocation, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </Grid>

                                            <!-- 详细/完整模式：备注 -->
                                            <TextBlock Grid.Row="4" Margin="12,4"
                                                       Text="{Binding Hint, StringFormat='备注: {0}'}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Detailed|Full'}" />

                                            <!-- 完整模式：票号、用途 -->
                                            <Grid Grid.Row="5" Margin="12,4"
                                                  Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Full'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TicketNumber, StringFormat='票号: {0}'}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Visibility="{Binding TicketNumber, Converter={StaticResource StringToVisibilityConverter}}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TicketPurpose}"
                                                           FontSize="{DynamicResource SmallFontSize}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Visibility="{Binding TicketPurpose, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </Grid>

                                            <!-- 完整模式：改签/退票标记 -->
                                            <TextBlock Grid.Row="6" Margin="12,4"
                                                       Text="{Binding TicketModificationType}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Full'}" />

                                            <!-- 完整模式：标签 -->
                                            <ItemsControl Grid.Row="7" Margin="12,4"
                                                          ItemsSource="{Binding Tags}"
                                                          Visibility="{Binding DataContext.Layout.CardContentDensity, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CardDensityToVisibilityConverter}, ConverterParameter='Full'}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource AccentBrush}" 
                                                                CornerRadius="3" 
                                                                Padding="4,2" 
                                                                Margin="0,0,4,2">
                                                            <TextBlock Text="{Binding Name}" 
                                                                       FontSize="{DynamicResource SmallFontSize}"
                                                                       Foreground="{DynamicResource AccentTextBrush}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 底部：金额（所有模式都显示） -->
                                            <Grid Grid.Row="8" Margin="12,6,12,10">
                                                <TextBlock Text="{Binding Money, StringFormat='{}{0:C}'}"
                                                           FontSize="{DynamicResource BaseFontSize}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                    <TextBlock Text="暂无数据"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding TripList.IsTripListExpanded}" Value="True" />
                                            <Condition Binding="{Binding TripItems.Count}" Value="0" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 分页控件 -->
                    <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" Padding="8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                            Visibility="{Binding TripList.IsTripListExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 左侧：统计信息 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="第" FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding CurrentPage}" FontSize="{DynamicResource SmallFontSize}"
                                           FontWeight="Bold" Margin="2,0" />
                                <TextBlock Text="/" FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding TotalPages}" FontSize="{DynamicResource SmallFontSize}"
                                           Margin="2,0" />
                                <TextBlock Text="页" FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="  共" FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0" />
                                <TextBlock Text="{Binding TotalItems}" FontSize="{DynamicResource SmallFontSize}"
                                           FontWeight="Bold" Margin="2,0" />
                                <TextBlock Text="条" FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>

                            <!-- 中间：分页按钮 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="◀" ToolTip="上一页" Command="{Binding PreviousPageCommandCommand}"
                                        Style="{StaticResource PaginationButtonStyle}" Margin="0,0,4,0" />
                                <ItemsControl ItemsSource="{Binding PaginationButtons}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Command="{Binding DataContext.GoToPageCommandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,2,0">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource PaginationButtonStyle}">
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource PanelBackgroundBrush}" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource TextPrimaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding
                                                                        Converter="{StaticResource PageNumberToStyleConverter}">
                                                                        <Binding />
                                                                        <Binding Path="DataContext.CurrentPage"
                                                                                RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource PrimaryBrush}" />
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="▶" ToolTip="下一页" Command="{Binding NextPageCommandCommand}"
                                        Style="{StaticResource PaginationButtonStyle}" Margin="4,0,0,0" />
                            </StackPanel>

                            <!-- 右侧：操作按钮 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="📤 导出"
                                        Command="{Binding ExportTripListCommand}"
                                        Style="{StaticResource StandardButtonStyle}"
                                        Margin="0,0,0,0"
                                        Padding="10,5"
                                        FontSize="{DynamicResource SmallFontSize}"
                                        ToolTip="导出行程"
                                        x:Name="ExportButton" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>