<UserControl x:Class="GuiPiao.View.OcrSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="{DynamicResource BaseFontSize}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- OCR环境状态 -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 OCR环境状态" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Python -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Python环境：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding PythonVersion}" VerticalAlignment="Center" Margin="5,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="✓" VerticalAlignment="Center" Margin="5,0,0,0"
                                           Foreground="#28A745" FontWeight="Bold"
                                           Visibility="{Binding IsPythonInstalled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <!-- CnOCR -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="CnOCR库：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="检查中..." />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecking}" Value="False">
                                                    <Setter Property="Text" Value="{Binding CnOCRStatusText}" />
                                                    <Setter Property="Foreground" Value="{Binding CnOCRStatusColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- CNSTD -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="CNSTD库：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="检查中..." />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecking}" Value="False">
                                                    <Setter Property="Text" Value="{Binding CnstdStatusText}" />
                                                    <Setter Property="Foreground" Value="{Binding CnstdStatusColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- 检测模型 -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="文本检测模型：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="检查中..." />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecking}" Value="False">
                                                    <Setter Property="Text" Value="{Binding DetectionStatusText}" />
                                                    <Setter Property="Foreground"
                                                            Value="{Binding DetectionStatusColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- 识别模型 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="文字识别模型：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="检查中..." />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecking}" Value="False">
                                                    <Setter Property="Text" Value="{Binding RecognitionStatusText}" />
                                                    <Setter Property="Foreground"
                                                            Value="{Binding RecognitionStatusColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <WrapPanel>
                            <Button Content="🔍 检查环境" Command="{Binding CheckEnvironmentCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,5" />
                            <Button Content="📦 一键安装" Command="{Binding InstallAllCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Padding="10,5" Margin="0,0,10,5"
                                    IsEnabled="{Binding IsEnvironmentCheckCompleted}" />
                        </WrapPanel>
                        <TextBlock Text="正在检测环境，请稍候..." FontSize="{DynamicResource SmallFontSize}" Margin="0,5,0,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Visibility="{Binding IsChecking, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- 进度条 -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Margin="0,10,0,0" Padding="10"
                                Visibility="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding InstallMessage}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding InstallProgress, StringFormat={}{0}%}"
                                               Margin="10,0,10,0"
                                               VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="Bold" />
                                    <!-- 暂停/恢复按钮 -->
                                    <Button Grid.Column="2" Content="{Binding DownloadButtonText}"
                                            Command="{Binding ToggleDownloadPauseCommand}"
                                            Visibility="{Binding ShowPauseButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Style="{StaticResource StandardButtonStyle}" Padding="10,3" />
                                </Grid>
                                <ProgressBar Value="{Binding InstallProgress}" Maximum="100" Height="20" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 模型导入 -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 模型导入" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <TextBlock.Text>
                                请下载以下两个模型文件，然后点击"选择模型文件"按钮导入：
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- 模型文件列表 -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Margin="0,0,0,10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="1. 识别模型（约12MB）：" FontWeight="Bold" Margin="0,0,0,5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="cnocr-v2.3-densenet_lite_136-gru-epoch=004-ft-model.onnx"
                                           Margin="15,0,0,10" FontFamily="Consolas"
                                           FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <TextBlock Text="2. 检测模型（约4MB）：" FontWeight="Bold" Margin="0,0,0,5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="ch_PP-OCRv4_det_infer.onnx"
                                           Margin="15,0,0,10" FontFamily="Consolas"
                                           FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- 下载来源 -->
                        <TextBlock Text="下载来源：" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="🔗 百度网盘下载" Command="{Binding OpenBaiduPanCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,0" />
                            <TextBlock Text="提取码：nocr" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" />
                        </StackPanel>

                        <!-- 导入按钮 -->
                        <Button Content="📂 选择模型文件" Command="{Binding ImportModelsCommand}"
                                Style="{StaticResource StandardButtonStyle}" Padding="10,5" HorizontalAlignment="Left" />

                        <TextBlock Text="提示：可同时选择两个.onnx文件，程序会自动识别并复制到正确位置"
                                   FontSize="{DynamicResource SmallFontSize}" Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- 单独安装组件 -->
                <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 单独安装组件" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="如果一键安装失败，可以单独安装以下组件："
                                   FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="🐍 仅安装Python" Command="{Binding InstallPythonCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,0" />
                            <Button Content="📚 仅安装CnOCR库" Command="{Binding InstallCnocrCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- OCR参数配置 -->
                <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 OCR参数配置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <!-- Python路径 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Python路径：" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox Text="{Binding PythonPathDisplay, Mode=OneWay}" VerticalAlignment="Center"
                                     Width="300"
                                     Margin="10,0"
                                     Padding="5" ToolTip="{Binding PythonPath}"
                                     IsReadOnly="True" />
                            <Button Content="浏览..." Command="{Binding BrowsePythonPathCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" />
                        </StackPanel>

                        <!-- 其他参数 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox Content="使用GPU加速" IsChecked="{Binding UseGpu}"
                                      Margin="0,0,20,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox Content="自动旋转图片" IsChecked="{Binding AutoRotateImage}"
                                      Margin="0,0,20,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox Content="启用图像预处理" IsChecked="{Binding EnableImagePreprocessing}"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <!-- 置信度阈值 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="置信度阈值：" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Slider Value="{Binding ConfidenceThreshold}" Minimum="0" Maximum="1"
                                    TickFrequency="0.05" Width="200" Margin="10,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConfidenceThreshold, StringFormat={}{0:P0}}"
                                       VerticalAlignment="Center" Width="40"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- OCR功能测试 -->
                <Border Grid.Row="4" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📌 OCR功能测试" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="测试OCR是否能正常工作，验证环境配置是否正确："
                                   FontSize="{DynamicResource SmallFontSize}" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox Text="{Binding TestImagePath}" VerticalAlignment="Center" Width="400"
                                     Padding="5" IsReadOnly="True" />
                            <Button Content="浏览..." Command="{Binding SelectTestImageCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="10,0,0,0" />
                        </StackPanel>

                        <Button Content="🧪 测试OCR识别" Command="{Binding TestOcrCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="15,8" HorizontalAlignment="Left"
                                IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBooleanConverter}}" />

                        <!-- 识别进度条 -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Margin="0,10,0,0" Padding="10"
                                Visibility="{Binding IsTesting, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding InstallMessage}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding InstallProgress, StringFormat={}{0}%}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="Bold" />
                                </Grid>
                                <ProgressBar Value="{Binding InstallProgress}" Maximum="100" Height="20" />
                            </StackPanel>
                        </Border>

                        <!-- 测试结果 -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Margin="0,10,0,0" Padding="10"
                                Visibility="{Binding IsTesting, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="测试结果：" FontWeight="Bold" Margin="0,0,0,5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding TestResult}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 保存设置" Command="{Binding SaveSettingsCommand}"
                        Padding="15,8" Margin="0,0,10,0" Style="{StaticResource StandardButtonStyle}" />
                <Button Content="🔄 恢复默认" Command="{Binding RestoreDefaultsCommand}"
                        Padding="15,8" Style="{StaticResource StandardButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>