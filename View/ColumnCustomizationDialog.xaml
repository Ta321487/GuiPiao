<Window x:Class="GuiPiao.Views.ColumnCustomizationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自定义列表字段"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="📋 自定义列表字段"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <!-- 字段列表 -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <ScrollViewer x:Name="ColumnsScrollViewer" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ColumnsListBox" Margin="10"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         PreviewMouseWheel="ColumnsListBox_PreviewMouseWheel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    AllowDrop="True"
                                    DragEnter="Border_DragEnter"
                                    DragLeave="Border_DragLeave"
                                    Drop="Border_Drop"
                                    MouseMove="Border_MouseMove"
                                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 拖拽手柄 -->
                                    <TextBlock Grid.Column="0"
                                               Text="☰"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Cursor="SizeAll" />

                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding IsVisible}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Header}"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding FieldName}"
                                                   FontSize="{DynamicResource SmallFontSize}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="3"
                                               Text="宽度:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />

                                    <TextBox Grid.Column="4"
                                             x:Name="WidthTextBox"
                                             Text="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding IsVisible}"
                                             ToolTip="数字＝固定像素；*＝可伸缩（详见下方说明）"
                                             PreviewTextInput="WidthTextBox_PreviewTextInput"
                                             DataObject.Pasting="WidthTextBox_Pasting" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- 说明文字 -->
        <StackPanel Grid.Row="2" Margin="0,10,0,10">
            <TextBlock FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8">
                <Run Text="提示：勾选字段以显示，拖拽 ☰ 可调整顺序。" />
                <LineBreak />
                <Run Text="「操作」列不在此列表中，宽度由界面设置里的操作按钮显隐决定。" />
            </TextBlock>
            <TextBlock FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap">
                <Run FontWeight="Bold" Text="列宽与铺满：" />
                <LineBreak />
                <Run Text="• 填数字＝该列固定为对应像素宽。" />
                <LineBreak />
                <Run Text="• 填 *＝可伸缩：在「当前已勾选且可见」的列里，从右往左第一个宽度为 * 的列会随窗口变宽，吸收表格剩余宽度（同一时刻只有这一列伸缩）。" />
                <LineBreak />
                <Run Text="• 若所有可见列都未填 *，则最后一列可见数据列会自动当作伸缩列，避免右侧大块空白（仍遵守各列「最小宽度」）。" />
                <LineBreak />
                <Run Text="• 若各列宽度与最小宽度之和大于窗口，会出现横向滚动条，属正常现象。" />
            </TextBlock>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="💾 确定"
                    Click="OkButton_Click"
                    Style="{StaticResource StandardButtonStyle}"
                    Padding="15,8"
                    Margin="0,0,10,0" />
            <Button Content="❌ 取消"
                    Click="CancelButton_Click"
                    Style="{StaticResource StandardButtonStyle}"
                    Padding="15,8" />
        </StackPanel>
    </Grid>
</Window>