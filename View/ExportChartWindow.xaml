<Window x:Class="GuiPiao.View.ExportChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="导出统计图表"
        Height="Auto"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="导出统计图表"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15" />

        <!-- 图表选择 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="选择要导出的图表"
                       FontSize="{DynamicResource BaseFontSize}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8" />
            <Border BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    Padding="10"
                    MaxHeight="150">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ChartSelectionItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding ChartName}"
                                          IsChecked="{Binding IsSelected}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="{DynamicResource BaseFontSize}"
                                          Margin="0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="全选"
                        Style="{StaticResource StandardButtonStyle}"
                        Padding="10,4"
                        Margin="0,0,10,0"
                        Click="SelectAll_Click" />
                <Button Content="取消全选"
                        Style="{StaticResource StandardButtonStyle}"
                        Padding="10,4"
                        Click="DeselectAll_Click" />
            </StackPanel>
        </StackPanel>

        <!-- 导出格式 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="导出格式"
                       FontSize="{DynamicResource BaseFontSize}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8" />
            <ComboBox x:Name="FormatComboBox"
                      SelectedIndex="0"
                      FontSize="{DynamicResource BaseFontSize}"
                      Padding="8,6">
                <ComboBoxItem Content="Excel 工作簿 (.xlsx)" Tag="Excel" />
                <ComboBoxItem Content="PDF 文档 (.pdf)" Tag="Pdf" />
                <ComboBoxItem Content="图片 (.png)" Tag="Image" />
            </ComboBox>
        </StackPanel>

        <!-- 选项 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="导出选项"
                       FontSize="{DynamicResource BaseFontSize}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8" />
            <CheckBox x:Name="IncludeRawDataCheckBox"
                      Content="包含原始数据"
                      IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontSize="{DynamicResource BaseFontSize}"
                      Margin="0,4" />
            <CheckBox x:Name="IncludeChartImageCheckBox"
                      Content="包含图表图片"
                      IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontSize="{DynamicResource BaseFontSize}"
                      Margin="0,4" />
        </StackPanel>

        <!-- 图片导出选项（仅图片格式时显示） -->
        <StackPanel Grid.Row="4" x:Name="ImageOptionsPanel" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock Text="图片导出设置"
                       FontSize="{DynamicResource BaseFontSize}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8" />
            <CheckBox x:Name="UseDefaultNamesCheckBox"
                      Content="使用图表名称作为文件名"
                      IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontSize="{DynamicResource BaseFontSize}"
                      Margin="0,4"
                      Checked="UseDefaultNamesCheckBox_CheckedChanged"
                      Unchecked="UseDefaultNamesCheckBox_CheckedChanged" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="文件夹名称"
                           FontSize="{DynamicResource BaseFontSize}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBox x:Name="FolderNameTextBox"
                         Text="统计图表"
                         FontSize="{DynamicResource BaseFontSize}"
                         Padding="8,4"
                         Margin="8,0,0,0"
                         MinWidth="180" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" x:Name="BaseFileNamePanel">
                <TextBlock Text="基础文件名"
                           FontSize="{DynamicResource BaseFontSize}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBox x:Name="BaseFileNameTextBox"
                         Text="图表"
                         FontSize="{DynamicResource BaseFontSize}"
                         Padding="8,4"
                         Margin="8,0,0,0"
                         MinWidth="180" />
            </StackPanel>
        </StackPanel>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="导出..."
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="100"
                    Margin="0,0,10,0"
                    Click="Export_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>