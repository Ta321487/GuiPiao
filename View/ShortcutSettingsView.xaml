<UserControl x:Class="GuiPiao.View.ShortcutSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="{DynamicResource BaseFontSize}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="10">
                <!-- 搜索框 -->
                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🔍 搜索快捷键" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,5" />
                            <Button Grid.Column="1" Content="搜索" Command="{Binding SearchCommand}" Margin="10,0,0,0"
                                    Padding="15,5" Style="{StaticResource StandardButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 编辑状态提示 -->
                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10"
                        Visibility="{Binding IsWaitingForKey, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⌨️ 请按下新的快捷键组合..." FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                        <Button Content="取消" Command="{Binding CancelEditCommand}" Margin="15,0,0,0" Padding="10,5"
                                Style="{StaticResource StandardButtonStyle}" />
                    </StackPanel>
                </Border>

                <!-- 冲突提示 -->
                <Border Background="#33FF4444" BorderBrush="#FF4444" BorderThickness="1" Margin="0,0,0,10" Padding="10"
                        Visibility="{Binding HasConflict, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="⚠️ 快捷键冲突" FontWeight="Bold" Foreground="#FF4444" Margin="0,0,0,5" />
                        <TextBlock Text="{Binding ConflictMessage}" Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- 快捷键列表 -->
                <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📋 快捷键列表" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <!-- 使用 DataGrid 保持与现有设计统一 -->
                        <DataGrid ItemsSource="{Binding Shortcuts}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  MaxHeight="350"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource ThemedDataGridColumnHeaderStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="8,6" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemedDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource HoverBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SelectedBackgroundBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <!-- 命令列 -->
                                <DataGridTextColumn Header="命令" Binding="{Binding ActionName}" Width="*" />

                                <!-- 键绑定列 -->
                                <DataGridTemplateColumn Header="键绑定" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Padding="5,3"
                                                    Cursor="Hand"
                                                    HorizontalAlignment="Center"
                                                    MinWidth="80"
                                                    MouseLeftButtonDown="ShortcutKeyBorder_MouseLeftButtonDown">
                                                <Border.Tag>
                                                    <Binding />
                                                </Border.Tag>
                                                <TextBlock Text="{Binding DisplayKey}" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 操作列 -->
                                <DataGridTemplateColumn Header="操作" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="↩️"
                                                    Width="40"
                                                    Padding="5"
                                                    Style="{StaticResource StandardButtonStyle}"
                                                    Command="{Binding DataContext.RestoreDefaultCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="恢复默认" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 提示文本 -->
                        <TextBlock Text="提示：点击键绑定列修改快捷键，点击 ↩️ 恢复默认" FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 保存设置" Command="{Binding SaveSettingsCommand}" Padding="15,8" Margin="0,0,10,0"
                        Style="{StaticResource StandardButtonStyle}" />
                <Button Content="🔄 恢复默认" Command="{Binding RestoreAllDefaultsCommand}" Padding="15,8"
                        Style="{StaticResource StandardButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>