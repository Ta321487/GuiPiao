<Window x:Class="GuiPiao.View.TagEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="编辑标签"
        Width="400"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   x:Name="TitleTextBlock"
                   Text="编辑标签"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,20" />

        <!-- 标签名称 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="标签名称："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,5" />

            <TextBox Grid.Row="1"
                     x:Name="NameTextBox"
                     Padding="8,4"
                     FontSize="{DynamicResource BaseFontSize}"
                     Background="{DynamicResource ContentBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" />
        </Grid>

        <!-- 背景颜色 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="背景颜色："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <WrapPanel Grid.Row="1" x:Name="ColorPanel">
                <!-- 颜色选项将由代码动态生成 -->
            </WrapPanel>
        </Grid>

        <!-- 文字颜色 -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="文字颜色："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <RadioButton x:Name="WhiteTextRadio"
                             Content="白色"
                             GroupName="TextColorGroup"
                             Margin="0,0,20,0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}" />
                <RadioButton x:Name="BlackTextRadio"
                             Content="黑色"
                             GroupName="TextColorGroup"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}" />
            </StackPanel>
        </Grid>

        <!-- 默认标签 -->
        <Grid Grid.Row="4" Margin="0,0,0,20">
            <CheckBox x:Name="DefaultTagCheckBox"
                      Content="设为默认标签（新建车票时自动选中）"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontSize="{DynamicResource BaseFontSize}" />
        </Grid>

        <!-- 预览 -->
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="预览："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <Border Grid.Row="1"
                    x:Name="PreviewBorder"
                    CornerRadius="4"
                    Padding="12,6"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="PreviewTextBlock"
                           Text="标签预览"
                           FontSize="{DynamicResource BaseFontSize}" />
            </Border>
        </Grid>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OkButton_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Height="32"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>