<Window x:Class="GuiPiao.View.BatchUpdateTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="批量更改标签"
        Width="500"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="批量更改车票标签"
                   FontSize="{DynamicResource LargeFontSize}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15" />

        <!-- 选中的车票列表 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="选中的车票："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,5" />

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    MaxHeight="150">
                <DataGrid x:Name="TicketsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ThemedDataGridCellStyle}"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource NormalScrollBarStyle}" />
                            </Style.Resources>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}" />
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="车次" Binding="{Binding TrainNo}" Width="80" />
                        <DataGridTextColumn Header="出发站" Binding="{Binding DepartStation}" Width="80" />
                        <DataGridTextColumn Header="到达站" Binding="{Binding ArriveStation}" Width="80" />
                        <DataGridTextColumn Header="出发日期"
                                            Binding="{Binding DepartDate, Converter={StaticResource DateFormatConverter}}"
                                            Width="90" />
                        <DataGridTextColumn Header="当前标签" Binding="{Binding CurrentTags}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- 目标标签选择 -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="选择标签："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <ComboBox Grid.Row="1"
                      x:Name="TagComboBox"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      FontSize="{DynamicResource BaseFontSize}"
                      Padding="8,4"
                      MinHeight="32" />
        </Grid>

        <!-- 标签更新模式选择 -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="更新方式："
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10" />

            <StackPanel Grid.Row="1" Orientation="Vertical">
                <RadioButton x:Name="ReplaceRadioButton"
                             Content="替换原有标签（清除现有标签后添加新标签）"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}"
                             Margin="0,0,0,5"
                             IsChecked="True" />
                <RadioButton x:Name="AppendRadioButton"
                             Content="追加标签（保留现有标签并添加新标签）"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="{DynamicResource BaseFontSize}" />
            </StackPanel>
        </Grid>

        <!-- 提示信息 -->
        <TextBlock Grid.Row="4"
                   Text="提示：更改标签不会影响车票的其他信息。"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="{DynamicResource SmallFontSize}"
                   TextWrapping="Wrap"
                   Margin="0,15,0,0" />

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Margin="0,0,10,0"
                    Click="OkButton_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    MinWidth="80"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>