<UserControl x:Class="GuiPiao.View.DashboardSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="{DynamicResource BaseFontSize}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 可用统计项库 -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📋 可用统计项库" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <DataGrid ItemsSource="{Binding AvailableStatistics}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Height="200">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource ThemedDataGridColumnHeaderStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="8,6" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemedDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource HoverBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SelectedBackgroundBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="统计项名称" Binding="{Binding Name}" Width="Auto" MinWidth="120" />
                                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*" />
                                <DataGridTemplateColumn Header="操作" Width="Auto" MinWidth="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="➕ 添加"
                                                    Command="{Binding DataContext.AddStatisticCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding Type}"
                                                    IsEnabled="{Binding DataContext.CanAddCard, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Style="{StaticResource TableActionButtonStyle}"
                                                    Padding="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 当前仪表盘卡片 -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🎴 当前仪表盘卡片（已添加/可拖拽排序/独立配置）"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CardCountText}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="{DynamicResource LargeFontSize}" />
                        </Grid>
                        <TextBlock Text="提示：仪表盘最多支持20个卡片，超出可能影响性能"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Margin="0,0,0,10" />

                        <DataGrid x:Name="CardsDataGrid"
                                  ItemsSource="{Binding Cards}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  MinHeight="150"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="CardsDataGrid_PreviewMouseLeftButtonDown"
                                  MouseMove="CardsDataGrid_MouseMove"
                                  DragOver="CardsDataGrid_DragOver"
                                  Drop="CardsDataGrid_Drop">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource ThemedDataGridColumnHeaderStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="8,6" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemedDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource HoverBackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SelectedBackgroundBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="Auto" MinWidth="30" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="☰"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Cursor="SizeAll"
                                                       ToolTip="拖动排序" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="卡片名称" Binding="{Binding Name}" Width="Auto" MinWidth="100"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="图表类型" Width="Auto" MinWidth="90" IsReadOnly="True">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="ChartType"
                                                 Converter="{StaticResource EnumToDescriptionConverter}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="时间范围" Width="Auto" MinWidth="100" IsReadOnly="True">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="TimeRange"
                                                 Converter="{StaticResource EnumToDescriptionConverter}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="操作" Width="Auto" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <WrapPanel>
                                                <Button Content="⚙️配置"
                                                        Command="{Binding DataContext.ConfigureCardCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource TableActionButtonStyle}"
                                                        Padding="8,2"
                                                        Margin="0,0,5,2" />
                                                <Button Content="🗑️删除"
                                                        Command="{Binding DataContext.RemoveCardCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource TableActionButtonStyle}"
                                                        Padding="8,2"
                                                        Margin="0,0,0,2" />
                                            </WrapPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 全局默认配置 -->
                <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📐 全局默认配置（可被单卡片覆盖）" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="布局方式：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedItem="{Binding LayoutType}"
                                      ItemsSource="{Binding LayoutTypes}" Margin="0,0,20,5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="卡片间距：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox x:Name="CardSpacingTextBox" MinWidth="40" VerticalAlignment="Center"
                                     Margin="0,0,5,5"
                                     Text="{Binding CardSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     LostFocus="CardSpacingTextBox_LostFocus" />
                            <TextBlock Text="px" VerticalAlignment="Center" Margin="0,0,20,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="全局时间范围：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox x:Name="GlobalTimeRangeComboBox" MinWidth="120"
                                      SelectedItem="{Binding GlobalTimeRange}"
                                      ItemsSource="{Binding TimeRangeTypes}"
                                      DropDownClosed="GlobalTimeRangeComboBox_DropDownClosed"
                                      Margin="0,0,20,5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="全局图表类型：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="120" SelectedItem="{Binding GlobalChartType}"
                                      ItemsSource="{Binding ChartTypes}" Margin="0,0,0,5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel>
                            <CheckBox Content="排除已退票/改签车票" IsChecked="{Binding ExcludeRefundedTickets}"
                                      VerticalAlignment="Center" Margin="0,0,20,5" />
                            <CheckBox Content="排除重复录入车票" IsChecked="{Binding ExcludeDuplicateTickets}"
                                      VerticalAlignment="Center" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 图表显示设置 -->
                <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🎨 图表显示设置" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel>
                            <CheckBox Content="启用图表动画" IsChecked="{Binding EnableChartAnimation}"
                                      VerticalAlignment="Center" Margin="0,0,20,5" />
                            <TextBlock Text="关闭动画可提升性能，适合低配置设备" VerticalAlignment="Center" Margin="0,0,0,5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource SmallFontSize}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 刷新策略 -->
                <Border Grid.Row="4" Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="🔄 刷新策略" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <WrapPanel>
                            <TextBlock Text="自动刷新：" VerticalAlignment="Center" Margin="0,0,5,5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ComboBox MinWidth="140" SelectedItem="{Binding AutoRefresh}"
                                      ItemsSource="{Binding AutoRefreshTypes}" Margin="0,0,20,5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button Content="🔄 立即刷新所有统计数据" Command="{Binding RefreshAllStatisticsCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,10,5" />
                            <Button Content="🧹 清除统计缓存" Command="{Binding ClearStatisticsCacheCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Padding="10,5" Margin="0,0,0,5" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <WrapPanel HorizontalAlignment="Right">
                <Button Content="💾 保存设置" Command="{Binding SaveSettingsCommand}"
                        Padding="15,8" Margin="0,0,10,0" Style="{StaticResource StandardButtonStyle}" />
                <Button Content="🔄 恢复默认" Command="{Binding RestoreDefaultsCommand}"
                        Padding="15,8" Style="{StaticResource StandardButtonStyle}" />
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>