<Window x:Class="GuiPiao.View.LogManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GuiPiao.ViewModel"
        xmlns:model="clr-namespace:GuiPiao.Model"
        xmlns:view="clr-namespace:GuiPiao.View"
        Title="日志管理 - 火车票管理系统"
        Height="600"
        Width="900"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.DataContext>
        <vm:LogManagerViewModel />
    </Window.DataContext>
    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource LargeFontSize}" />
        </Style>
        <Style x:Key="BaseTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="📌 日志筛选" Style="{StaticResource HeaderTextStyle}" />
                    <StackPanel>
                        <!-- 第一行：日志级别和时间区间 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="日志级别：" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Style="{StaticResource BaseTextStyle}" />
                            <ComboBox MinWidth="100" SelectedItem="{Binding SelectedLogLevel}" Margin="0,0,20,0"
                                      FontSize="{DynamicResource BaseFontSize}">
                                <model:LogLevel>ALL</model:LogLevel>
                                <model:LogLevel>INFO</model:LogLevel>
                                <model:LogLevel>WARN</model:LogLevel>
                                <model:LogLevel>ERROR</model:LogLevel>
                                <model:LogLevel>FATAL</model:LogLevel>
                            </ComboBox>

                            <TextBlock Text="时间区间：" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Style="{StaticResource BaseTextStyle}" />
                            <view:ThemedDatePicker MinWidth="120" SelectedDate="{Binding StartDate}" Margin="0,0,5,0" />
                            <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,5,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Style="{StaticResource BaseTextStyle}" />
                            <view:ThemedDatePicker MinWidth="120" SelectedDate="{Binding EndDate}" Margin="0,0,0,0" />
                        </StackPanel>

                        <!-- 第二行：关键词检索和按钮 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="关键词检索：" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Style="{StaticResource BaseTextStyle}" />
                            <TextBox MinWidth="200" Text="{Binding Keyword}" Margin="0,0,10,0"
                                     FontSize="{DynamicResource BaseFontSize}" />
                            <Button Content="🔎 检索" Command="{Binding SearchCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,0" />
                            <Button Content="🗑️ 清空条件" Command="{Binding ClearConditionsCommand}"
                                    Style="{StaticResource StandardButtonStyle}" Margin="0,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📌 日志列表" Style="{StaticResource HeaderTextStyle}" />

                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding LogItems}"
                              IsReadOnly="True" SelectionMode="Extended"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              RowStyle="{StaticResource ThemedDataGridRowStyle}"
                              CellStyle="{StaticResource ThemedDataGridCellStyle}"
                              ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                              SelectionChanged="DataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Width="Auto" MinWidth="60" Binding="{Binding Id}" />
                            <DataGridTextColumn Header="时间" Width="Auto" MinWidth="150" Binding="{Binding Time}" />
                            <DataGridTemplateColumn Header="级别" Width="Auto" MinWidth="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LevelDisplay}" Foreground="{Binding LevelColor}"
                                                   FontWeight="Bold" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="模块" Width="Auto" MinWidth="100" Binding="{Binding Module}" />
                            <DataGridTextColumn Header="日志内容" Width="*" MinWidth="200" Binding="{Binding Content}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="📌 日志操作" Style="{StaticResource HeaderTextStyle}" />
                    <WrapPanel>
                        <Button Content="📤 导出选中日志" Command="{Binding ExportSelectedLogsCommand}"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Button Content="📤 导出全部日志" Command="{Binding ExportAllLogsCommand}"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Button Content="🗑️ 清空7天前日志" Command="{Binding DeleteOldLogsCommand}"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Button Content="🗑️ 清空所有日志" Command="{Binding DeleteAllLogsCommand}"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Button Content="🔄 刷新" Command="{Binding RefreshCommand}"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Separator Margin="5,0,10,5" Background="{DynamicResource BorderBrush}" Width="1"
                                   Style="{x:Null}" />
                        <Button Content="📋 日志设置" Click="OpenLogSettings_Click"
                                Style="{StaticResource StandardButtonStyle}" Margin="0,0,5,5" />
                        <Button Content="❌ 关闭" Click="Close_Click" Style="{StaticResource StandardButtonStyle}"
                                Margin="0,0,0,5" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 状态栏 -->
            <StatusBar Grid.Row="3" Background="{DynamicResource StatusBarBackgroundBrush}">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🟢 " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="日志：" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TotalLogCount}" VerticalAlignment="Center" />
                        <TextBlock Text=" 条" VerticalAlignment="Center" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </DockPanel>
</Window>