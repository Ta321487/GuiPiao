<Window x:Class="GuiPiao.View.CustomTimeRangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:view="clr-namespace:GuiPiao.View"
        Title="选择自定义时间范围"
        Width="420"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="选择自定义时间范围"
                   FontSize="{DynamicResource TitleFontSize}"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <!-- 开始日期 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="开始日期："
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="{DynamicResource BaseFontSize}" />
            <view:ThemedDatePicker Grid.Column="1"
                                   x:Name="StartDatePicker"
                                   SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Watermark="选择日期" />
            <TextBlock Grid.Column="2"
                       Text="（默认：近12个月）"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource SmallFontSize}" />
        </Grid>

        <!-- 结束日期 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="结束日期："
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="{DynamicResource BaseFontSize}" />
            <view:ThemedDatePicker Grid.Column="1"
                                   x:Name="EndDatePicker"
                                   SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   Watermark="选择日期" />
            <TextBlock Grid.Column="2"
                       Text=""
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource SmallFontSize}" />
        </Grid>

        <!-- 提示信息区域 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <!-- 时间粒度建议提示（始终尝试显示） -->
            <TextBlock Text="{Binding TimeGranularityHint}"
                       Foreground="{DynamicResource InfoBrush}"
                       FontSize="{DynamicResource SmallFontSize}"
                       TextWrapping="Wrap"
                       Visibility="{Binding TimeGranularityHint, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Content="确认"
                    x:Name="ConfirmButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="ConfirmButton_Click" />
            <Button Content="重置"
                    Style="{StaticResource StandardButtonStyle}"
                    Width="Auto"
                    MinWidth="80"
                    Margin="5,0"
                    Click="ResetButton_Click" />
            <Button Content="取消"
                    Style="{StaticResource StandardButtonStyle}"
                    Width="Auto"
                    MinWidth="80"
                    Margin="5,0"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>