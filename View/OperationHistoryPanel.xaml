<UserControl x:Class="GuiPiao.View.OperationHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GuiPiao.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="250">
    <UserControl.Resources>
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
    </UserControl.Resources>
    <Grid x:Name="RootGrid">
        <!-- 主面板 -->
        <Border x:Name="MainPanel"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Width="250"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="4,4,0,0"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="操作历史"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="✕"
                                Click="OnCollapseClick"
                                Style="{StaticResource StandardButtonStyle}"
                                Width="24"
                                Height="24"
                                FontSize="12"
                                Padding="0" />
                    </Grid>
                </Border>

                <!-- 操作列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HistoryItemsControl"
                                  Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="{DynamicResource BaseFontSize}"
                                                   Foreground="{Binding IsUndone, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Undone}"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUndone}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding NewValue}"
                                                   FontSize="{DynamicResource SmallFontSize}"
                                                   Foreground="{Binding IsUndone, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Undone}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="220">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUndone}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                   FontSize="{DynamicResource SmallFontSize}"
                                                   Foreground="{Binding IsUndone, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=UndoneTimestamp}"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUndone}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 展开按钮（面板折叠时显示） -->
        <Button x:Name="ExpandButton"
                Content="📋 历史"
                Click="OnExpandClick"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Padding="10,4"
                Height="30"
                Style="{StaticResource StandardButtonStyle}" />
    </Grid>
</UserControl>