<UserControl x:Class="GuiPiao.View.DashboardChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="250"
             d:DesignWidth="300">
    <UserControl.Resources>
        <!-- 饼图模板 -->
        <DataTemplate x:Key="PieChartTemplate">
            <lvc:PieChart Series="{Binding Series}"
                          MinHeight="180"
                          MaxHeight="250"
                          Background="Transparent"
                          IsHitTestVisible="True"
                          TooltipPosition="{Binding PieTooltipPosition}"
                          TooltipTextPaint="{Binding TooltipTextPaint}"
                          TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                          TooltipTextSize="{Binding TooltipTextSize}"
                          AnimationsSpeed="{Binding AnimationSpeed}"
                          EasingFunction="{Binding AnimationEasingFunction}"
                          Loaded="Chart_Loaded" />
        </DataTemplate>

        <!-- 笛卡尔图表模板 -->
        <DataTemplate x:Key="CartesianChartTemplate">
            <lvc:CartesianChart Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                MinHeight="180"
                                MaxHeight="250"
                                TooltipPosition="{Binding TooltipPosition}"
                                TooltipTextPaint="{Binding TooltipTextPaint}"
                                TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                TooltipTextSize="{Binding TooltipTextSize}"
                                AnimationsSpeed="{Binding AnimationSpeed}"
                                EasingFunction="{Binding AnimationEasingFunction}"
                                Loaded="Chart_Loaded" />
        </DataTemplate>

        <!-- 文本列表模板 -->
        <DataTemplate x:Key="TextListTemplate">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ChartData.TextListItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource PanelBackgroundBrush}"
            Margin="5"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 拖拽手柄 -->
                <TextBlock Grid.Column="0"
                           Text="☰"
                           FontSize="16"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Cursor="SizeAll"
                           ToolTip="拖动排序" />

                <!-- 标题 -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontWeight="Bold"
                           FontSize="{DynamicResource LargeFontSize}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           ToolTip="{Binding Title}" />

                <!-- 全屏按钮 -->
                <Button Grid.Column="2"
                        Content="全屏"
                        Command="{Binding DataContext.EnterFullscreenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource StandardButtonStyle}"
                        MinWidth="50"
                        FontSize="{DynamicResource SmallFontSize}"
                        Padding="8,2"
                        ToolTip="全屏查看"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- 图表区域 -->
            <Grid Grid.Row="1" Margin="20,0,20,30">
                <!-- 有数据时显示图表 -->
                <ContentControl Content="{Binding}"
                                Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate"
                                                Value="{StaticResource CartesianChartTemplate}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPieChart}" Value="True">
                                                <Setter Property="ContentTemplate"
                                                        Value="{StaticResource PieChartTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTextList}" Value="True">
                                                <Setter Property="ContentTemplate"
                                                        Value="{StaticResource TextListTemplate}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- 无数据时显示提示 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasData, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,5"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="暂无数据" FontSize="{DynamicResource BaseFontSize}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>