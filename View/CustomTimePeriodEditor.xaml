<UserControl x:Class="GuiPiao.View.CustomTimePeriodEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 预设模板 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="预设模板:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White" />
            <ComboBox x:Name="TemplateComboBox" Width="180" SelectedIndex="0">
                <ComboBoxItem Content="4段（凌晨/早/中/晚）" />
                <ComboBoxItem Content="6段（细粒度）" />
                <ComboBoxItem Content="通勤模式（早/晚高峰）" />
            </ComboBox>
            <Button x:Name="ApplyTemplateButton" Content="应用模板" Margin="10,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ApplyTemplateButton_Click" />
        </StackPanel>

        <!-- 时段列表 -->
        <TextBlock Grid.Row="1" Text="当前时段划分:" Foreground="White" Margin="0,0,0,5" />

        <Border Grid.Row="2" Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 时段列表 -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PeriodsItemsControl" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3E3E42" CornerRadius="4" Margin="0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 颜色指示器（仅在饼图时显示） -->
                                        <Border x:Name="ColorIndicator" Grid.Column="0" Width="20" Height="20"
                                                CornerRadius="3"
                                                Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}" />

                                        <!-- 时段信息 -->
                                        <StackPanel Grid.Column="1" Margin="10,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" />
                                            <TextBlock Text="{Binding TimeRange}" Foreground="#AAAAAA" FontSize="12" />
                                        </StackPanel>

                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="编辑" Tag="{Binding}" Click="EditButton_Click"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Margin="0,0,5,0" />
                                            <Button Content="删除" Tag="{Binding}" Click="DeleteButton_Click"
                                                    Style="{StaticResource SmallButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 添加按钮 -->
                <Button Grid.Row="1" x:Name="AddPeriodButton" Content="+ 添加新时段"
                        HorizontalAlignment="Left" Margin="10"
                        Style="{StaticResource StandardButtonStyle}"
                        Click="AddPeriodButton_Click" />
            </Grid>
        </Border>

        <!-- 编辑面板（默认隐藏） -->
        <Border Grid.Row="3" x:Name="EditPanel" Background="#252526" BorderBrush="#3E3E42"
                BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="15" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="编辑时段" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="名称:" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,10,5" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="PeriodNameTextBox" Margin="0,0,0,5" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="时间范围:" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,10,5" />
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBox x:Name="StartHourTextBox" Width="40" Text="00" MaxLength="2"
                             PreviewTextInput="TimeTextBox_PreviewTextInput"
                             DataObject.Pasting="TimeTextBox_Pasting" />
                    <TextBlock Text=":" Foreground="White" VerticalAlignment="Center" Margin="2,0" />
                    <TextBox x:Name="StartMinuteTextBox" Width="40" Text="00" MaxLength="2"
                             PreviewTextInput="TimeTextBox_PreviewTextInput"
                             DataObject.Pasting="TimeTextBox_Pasting" />
                    <TextBlock Text=" - " Foreground="White" VerticalAlignment="Center" Margin="5,0" />
                    <TextBox x:Name="EndHourTextBox" Width="40" Text="06" MaxLength="2"
                             PreviewTextInput="TimeTextBox_PreviewTextInput"
                             DataObject.Pasting="TimeTextBox_Pasting" />
                    <TextBlock Text=":" Foreground="White" VerticalAlignment="Center" Margin="2,0" />
                    <TextBox x:Name="EndMinuteTextBox" Width="40" Text="00" MaxLength="2"
                             PreviewTextInput="TimeTextBox_PreviewTextInput"
                             DataObject.Pasting="TimeTextBox_Pasting" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="SaveButton" Content="保存" Click="SaveButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,10,0" />
                    <Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click"
                            Style="{StaticResource BaseButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>