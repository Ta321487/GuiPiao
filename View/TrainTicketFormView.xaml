<UserControl x:Class="GuiPiao.View.TrainTicketFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:view="clr-namespace:GuiPiao.View"
             xmlns:controls="clr-namespace:GuiPiao.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- 主要信息区域 -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧列 -->
                    <StackPanel Grid.Column="0">
                        <!-- 车次号 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="车次号 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding TrainNoPrefixes}"
                                          SelectedItem="{Binding SelectedTrainNoPrefix}"
                                          Width="70"
                                          FontSize="{DynamicResource BaseFontSize}"
                                          Padding="8,6"
                                          MinHeight="{DynamicResource StandardRowHeight}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding TrainNoNumber}"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}"
                                         PreviewTextInput="TrainNoNumber_PreviewTextInput" />
                            </Grid>
                        </StackPanel>

                        <!-- 出发车站 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="出发车站 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <controls:AutoCompleteTextBox Grid.Column="0"
                                                              Text="{Binding DepartStationInput}"
                                                              Suggestions="{Binding DepartStationSuggestions}"
                                                              IsDropDownOpen="{Binding IsDepartStationDropdownOpen}"
                                                              SelectedIndex="{Binding DepartStationSelectedIndex}"
                                                              TextChangedCommand="{Binding DepartStationTextChangedCommand}"
                                                              SelectItemCommand="{Binding SelectDepartStationCommand}"
                                                              IsReadOnly="{Binding IsDepartStationReadOnly}"
                                                              Padding="8,6"
                                                              MinHeight="{DynamicResource StandardRowHeight}" />
                                <TextBlock Grid.Column="1"
                                           Text="站"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </StackPanel>

                        <!-- 到达车站 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="到达车站 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <controls:AutoCompleteTextBox Grid.Column="0"
                                                              Text="{Binding ArriveStationInput}"
                                                              Suggestions="{Binding ArriveStationSuggestions}"
                                                              IsDropDownOpen="{Binding IsArriveStationDropdownOpen}"
                                                              SelectedIndex="{Binding ArriveStationSelectedIndex}"
                                                              TextChangedCommand="{Binding ArriveStationTextChangedCommand}"
                                                              SelectItemCommand="{Binding SelectArriveStationCommand}"
                                                              IsReadOnly="{Binding IsArriveStationReadOnly}"
                                                              Padding="8,6"
                                                              MinHeight="{DynamicResource StandardRowHeight}" />
                                <TextBlock Grid.Column="1"
                                           Text="站"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </StackPanel>

                        <!-- 出发日期 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="出发日期 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <view:ThemedDatePicker SelectedDate="{Binding DepartDateTime, Mode=TwoWay}"
                                                   Watermark="选择出发日期"
                                                   FontSize="{DynamicResource BaseFontSize}"
                                                   MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 出发时间 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="出发时间 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <view:ThemedTimePicker SelectedTime="{Binding DepartTimeValue, Mode=TwoWay}"
                                                   Watermark="选择出发时间"
                                                   HeaderText="选择出发时间"
                                                   FontSize="{DynamicResource BaseFontSize}"
                                                   MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 席别 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="席别 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding SeatTypeOptions}"
                                      SelectedItem="{Binding SeatType}"
                                      FontSize="{DynamicResource BaseFontSize}"
                                      Padding="8,6"
                                      MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 座位号 -->
                        <StackPanel>
                            <TextBlock Text="座位号 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding SeatNoNumber}"
                                         Width="70"
                                         IsEnabled="{Binding IsSeatNoInputEnabled}"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}" />
                                <ComboBox ItemsSource="{Binding SeatLetterOptions}"
                                          SelectedItem="{Binding SelectedSeatLetter}"
                                          Width="55"
                                          Margin="8,0,0,0"
                                          IsEnabled="{Binding IsSeatLetterEnabled}"
                                          Visibility="{Binding IsSeatLetterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          FontSize="{DynamicResource BaseFontSize}"
                                          Padding="8,6"
                                          MinHeight="{DynamicResource StandardRowHeight}" />
                                <CheckBox Content="无座"
                                          IsChecked="{Binding IsNoSeat}"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          FontSize="{DynamicResource BaseFontSize}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧列 -->
                    <StackPanel Grid.Column="2">
                        <!-- 车厢号 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="车厢号 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding CoachNoInput}"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}" />
                                <TextBlock Grid.Column="1"
                                           Text="车"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </StackPanel>

                        <!-- 取票号 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="取票号" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding TicketNumber}"
                                     FontSize="{DynamicResource BaseFontSize}"
                                     Padding="8,6"
                                     MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 检票位置 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="检票位置" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding CheckInLocation}"
                                     FontSize="{DynamicResource BaseFontSize}"
                                     Padding="8,6"
                                     MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 附加信息 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="附加信息" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AdditionalInfoOptions}"
                                      SelectedItem="{Binding AdditionalInfo}"
                                      FontSize="{DynamicResource BaseFontSize}"
                                      Padding="8,6"
                                      MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 车票用途 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="车票用途" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding TicketPurposeOptions}"
                                      SelectedItem="{Binding TicketPurpose}"
                                      FontSize="{DynamicResource BaseFontSize}"
                                      Padding="8,6"
                                      MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 改签类型 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="改签类型" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding TicketModificationTypeOptions}"
                                      SelectedItem="{Binding TicketModificationType}"
                                      FontSize="{DynamicResource BaseFontSize}"
                                      Padding="8,6"
                                      MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 状态（仅新增窗口） -->
                        <StackPanel Margin="0,0,0,12"
                                    Visibility="{Binding IsStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="状态 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatus}"
                                      FontSize="{DynamicResource BaseFontSize}"
                                      Padding="8,6"
                                      MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>

                        <!-- 金额 -->
                        <StackPanel>
                            <TextBlock Text="金额 *" FontSize="{DynamicResource BaseFontSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MoneyText}"
                                     FontSize="{DynamicResource BaseFontSize}"
                                     Padding="8,6"
                                     MinHeight="{DynamicResource StandardRowHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 票种类型区域 -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="票种类型"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="学生票"
                                  IsChecked="{Binding IsStudentTicket}"
                                  Margin="0,0,24,0"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="优惠票"
                                  IsChecked="{Binding IsDiscountTicket}"
                                  Margin="0,0,24,0"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="网络售票"
                                  IsChecked="{Binding IsOnlineTicket}"
                                  Margin="0,0,24,0"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="儿童票"
                                  IsChecked="{Binding IsChildTicket}"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 支付渠道区域 -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="支付渠道"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="支付宝售票"
                                  IsChecked="{Binding IsAlipay}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="微信售票"
                                  IsChecked="{Binding IsWeChat}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="农业银行"
                                  IsChecked="{Binding IsABC}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="建设银行"
                                  IsChecked="{Binding IsCCB}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="工商银行"
                                  IsChecked="{Binding IsICBC}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="交通银行"
                                  IsChecked="{Binding IsBCOM}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="招商银行"
                                  IsChecked="{Binding IsCMB}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="邮储银行"
                                  IsChecked="{Binding IsPSBC}"
                                  Margin="0,0,20,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                        <CheckBox Content="中国银行"
                                  IsChecked="{Binding IsBOC}"
                                  Margin="0,0,0,8"
                                  VerticalAlignment="Center"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 标签选择区域 -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="标签"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <!-- 标签列表 -->
                    <ItemsControl x:Name="TagsItemsControl" ItemsSource="{Binding AvailableTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="TagBorder"
                                        Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                        CornerRadius="12"
                                        Padding="10,5"
                                        Margin="0,0,8,8"
                                        Cursor="Hand"
                                        Opacity="0.5"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        MouseLeftButtonDown="OnTagClicked">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{Binding TextColor, Converter={StaticResource StringToBrushConverter}}"
                                               FontSize="{DynamicResource BaseFontSize}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 其他信息区域 -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="其他信息"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 左侧 -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="出发车站代码:"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding DepartStationCode}"
                                         IsReadOnly="True"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}"
                                         Background="{DynamicResource ControlDisabledBrush}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="到达车站代码:"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding ArriveStationCode}"
                                         IsReadOnly="True"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}"
                                         Background="{DynamicResource ControlDisabledBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 右侧 -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="出发车站拼音:"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding DepartStationPinyin}"
                                         IsReadOnly="True"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}"
                                         Background="{DynamicResource ControlDisabledBrush}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="到达车站拼音:"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding ArriveStationPinyin}"
                                         IsReadOnly="True"
                                         FontSize="{DynamicResource BaseFontSize}"
                                         Padding="8,6"
                                         MinHeight="{DynamicResource StandardRowHeight}"
                                         Background="{DynamicResource ControlDisabledBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- 提示信息 -->
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="提示信息:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox x:Name="HintComboBox"
                                  ItemsSource="{Binding HintOptions}"
                                  SelectedItem="{Binding SelectedHint}"
                                  IsEditable="False"
                                  SelectionChanged="HintComboBox_SelectionChanged"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  Padding="8,6"
                                  MinHeight="{DynamicResource StandardRowHeight}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>